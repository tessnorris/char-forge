// Character Forge application model records
//
// This module owns app-level state shapes: document identity, editor-only
// selection state, TEA messages, and the model shell. None of this is D&D
// rules logic, and none of it stores derived character values.

import * from "../character/character";
import * from "../character/resources";
import * from "../content/contentpack";
import * from "../builder/abilitybuilder";

export type CharacterDocument = { id, character, turn }


export type BuilderSelection = {
  activeTab,
  builderStep,
  equipmentCategory,
  equipmentSearch,
  expandedSections,

  abilityMethod,

  // Ability score assignment state.
  //
  // These fields belong to the builder/editor layer, not the character domain.
  // `standardSelectedScore` stores the selected slot id. The per-ability fields
  // store assigned slot ids. Slot values are text so the UI can keep duplicate
  // rolled values distinct by slot id.
  standardSelectedScore,
  standardStrength,
  standardDexterity,
  standardConstitution,
  standardIntelligence,
  standardWisdom,
  standardCharisma,
  scoreSlotOne,
  scoreSlotTwo,
  scoreSlotThree,
  scoreSlotFour,
  scoreSlotFive,
  scoreSlotSix,

  backgroundBonusMode,
  backgroundBonusPrimary,
  backgroundBonusSecondary,
  backgroundBonusTertiary,

  rollMode,
  rollSeed,
  rollSummary
}
export type Model = { catalog, contentPacks, documents, selectedId, character, turn, status, damageText, healingText, tempText, saveText, importText, selection }
export type UpdateResult = { model, cmd }

