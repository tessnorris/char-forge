export function makeCharacterDocument(id, character, turn) {
  CharacterDocument(
    id = id,
    character = character,
    turn = turn
  );
}

export function documentName(doc) {
  doc.character.build.identity.name;
}

export function documentLevel(doc) {
  doc.character.build.level;
}

export function documentSummary(doc) {
  let build = doc.character.build;
  "Level " + __str__(build.level) + " " + speciesName(build.species) + " " + className(build.class);
}

export function documentButtonLabel(doc) {
  documentName(doc) + " — " + documentSummary(doc);
}
