  ];
}

function viewGoliathOptions(build) {
  panel("Giant ancestry", [
    vp([vtext("Choose the Giant ancestry that determines the Goliath's special trait.")]),
    field("Ancestry", voptionButtonGroup("goliath-ancestry", goliathAncestryOptions(), goliathAncestryId(build.speciesOptions.goliathAncestry), fn v => SetGoliathAncestry { value = v })),
    vfieldBlock("Selected ancestry", [
      row("Ancestry", goliathAncestryName(build.speciesOptions.goliathAncestry))
    ])
  ]);
}

function humanFeatOptions() {
  [
    voption("skilled", "Skilled", "★"),
    voption("alert", "Alert", "⚑"),
    voption("lucky", "Lucky", "✦"),
    voption("tough", "Tough", "⬤")
  ];
}

function humanFeatName(id) {
  if id == "alert" then "Alert"
  else if id == "lucky" then "Lucky"
  else if id == "tough" then "Tough"
  else "Skilled";
}

function viewHumanOptions(build) {
  panel("Human options", [
    vp([vtext("Choose the extra skill and Origin feat for this Human.")]),
    field("Bonus skill", voptionButtonGroup("human-skill", coreSkillOptions(), skillId(build.speciesOptions.humanBonusSkill), fn v => SetHumanBonusSkill { value = v })),
    field("Bonus feat", voptionButtonGroup("human-feat", humanFeatOptions(), build.speciesOptions.humanBonusFeat, fn v => SetHumanBonusFeat { value = v })),
    vfieldBlock("Selected options", [
      row("Skill", skillName(build.speciesOptions.humanBonusSkill)),
      row("Feat", humanFeatName(build.speciesOptions.humanBonusFeat))
    ])
  ]);
}

function tieflingLineageOptions() {
  [
    voption("abyssal", "Abyssal", "☠"),
    voption("chthonic", "Chthonic", "☾"),
    voption("infernal", "Infernal", "🔥")
  ];
}

function viewTieflingOptions(build) {
  let lineage = build.speciesOptions.tieflingLineage;
  panel("Fiendish legacy", [
    vp([vtext("Choose the legacy and spellcasting ability for Tiefling magic.")]),
    field("Legacy", voptionButtonGroup("tiefling-lineage", tieflingLineageOptions(), tieflingLineageId(lineage), fn v => SetTieflingLineage { value = v })),
    field("Spellcasting ability", voptionButtonGroup("tiefling-casting", spellAbilityOptions(), build.speciesOptions.lineageSpellcastingAbility, fn v => SetLineageSpellcastingAbility { value = v })),
    vfieldBlock("Selected legacy", [
      row("Legacy", tieflingLineageName(lineage)),
      row("Resistance", tieflingLineageResistance(lineage)),
      row("Casting ability", abilitySpellcastingName(build.speciesOptions.lineageSpellcastingAbility))
    ])
  ]);
}

function speciesOptionViews(build) {
  let name = speciesName(build.species);
  if name == "Dragonborn" then
    [viewDragonbornOptions(build)]
  else if name == "Elf" then
    [viewElfLineageOptions(build)]
  else if name == "Gnome" then
    [viewGnomeOptions(build)]
  else if name == "Goliath" then
    [viewGoliathOptions(build)]
  else if name == "Human" then
    [viewHumanOptions(build)]
  else if name == "Tiefling" then
    [viewTieflingOptions(build)]
  else
    [panel("No species options", [vp([vtext("This species has no extra setup choices.")])])];
}

function skillNameList(skills) {
  join([skillName(s) for s <- skills], ", ");
}

function skillChoice(skill) {
  choice(skillId(skill), skillName(skill));
}

function skillChoices(skills) {
  [skillChoice(s) for s <- skills];
}

function fightingStyleOptions() {
  [
    voption("archery", "Archery", "🏹"),
    voption("defense", "Defense", "🛡"),
    voption("dueling", "Dueling", "⚔"),
    voption("great-weapon", "Great Weapon", "🗡"),
    voption("protection", "Protection", "✋"),
    voption("two-weapon", "Two-Weapon", "✦")
  ];
}

function clericOrderOptions() {
  [
    voption("protector", "Protector", "🛡"),
    voption("thaumaturge", "Thaumaturge", "✦")
  ];
}

function druidOrderOptions() {
  [
    voption("magician", "Magician", "✦"),
    voption("warden", "Warden", "🌿")
  ];
}

function lockedClassSkills(build) {
  speciesSkillProficienciesForBuild(build) + backgroundSkillProficiencies(build.background);
}

function alphabeticalSkills() {
  [Acrobatics, AnimalHandling, Arcana, Athletics, Deception, History, Insight, Intimidation, Investigation, Medicine, Nature, Perception, Performance, Persuasion, Religion, SleightOfHand, Stealth, Survival];
}

function lockedSkillSource(build, skill) {
  let speciesLocked = hasSelectedClassSkill(skill, speciesSkillProficienciesForBuild(build));
  let backgroundLocked = hasSelectedClassSkill(skill, backgroundSkillProficiencies(build.background));
  if speciesLocked && backgroundLocked then
    speciesName(build.species) + " + " + backgroundName(build.background)
  else if speciesLocked then
    speciesName(build.species)
  else if backgroundLocked then
    backgroundName(build.background)
  else
    "";
}

function classSkillOptionState(build, skill) {
  let locked = hasSelectedClassSkill(skill, lockedClassSkills(build));
  let chosen = hasSelectedClassSkill(skill, build.classOptions.classSkills);
  let classSkill = hasSelectedClassSkill(skill, classSkillOptions(build.class));
  if locked then
    OptionLocked { lockedSkillSource(build, skill) }
  else if chosen then
    OptionSelected
  else if classSkill then
    OptionAvailable
  else
    OptionDisabled;
}

function classSkillLabel(build, skill) {
  skillName(skill);
}

function classSkillChoice(build, skill) {
  vchoice(skillId(skill), classSkillLabel(build, skill), "•", classSkillOptionState(build, skill));
}

function classSkillChoices(build) {
  [classSkillChoice(build, s) for s <- alphabeticalSkills()];
}

function viewClassSkillSelector(build) {
  let selected = length(build.classOptions.classSkills);
  let required = classSkillChoiceCount(build.class);
  panel("Class skills", [
    vp([vtext("Choose class skill proficiencies. Orange skills are selected. Locked skills show where they came from, and unavailable skills are disabled.")]),
    row("Class", className(build.class)),
    row("Needed", __str__(selected) + " / " + __str__(required)),
    field("Skills", vchoiceGroup("class-skill", classSkillChoices(build), fn v => SetClassSkill { value = v }))
  ]);
}

function viewFightingStyleOption(build) {
  if hasFightingStyleOption(build.class) then
    [panel("Fighting style", [
      vp([vtext("Choose the fighting style this class grants when available at this level.")]),
      field("Style", voptionButtonGroup("fighting-style", fightingStyleOptions(), fightingStyleId(build.classOptions.fightingStyle), fn v => SetFightingStyle { value = v })),
      row("Selected", fightingStyleName(build.classOptions.fightingStyle))
    ])]
  else
    [];
}

function viewClericOrderOption(build) {
  if hasClericOrderOption(build.class) then
    [panel("Divine Order", [
      vp([vtext("Choose the cleric's initial order.")]),
      field("Order", voptionButtonGroup("cleric-order", clericOrderOptions(), clericOrderId(build.classOptions.clericOrder), fn v => SetClericOrder { value = v })),
      row("Selected", clericOrderName(build.classOptions.clericOrder))
    ])]
  else
    [];
}

function viewDruidOrderOption(build) {
  if hasDruidOrderOption(build.class) then
    [panel("Primal Order", [
      vp([vtext("Choose the druid's initial order.")]),
      field("Order", voptionButtonGroup("druid-order", druidOrderOptions(), druidOrderId(build.classOptions.druidOrder), fn v => SetDruidOrder { value = v })),
      row("Selected", druidOrderName(build.classOptions.druidOrder))
    ])]
  else
    [];
}

function viewExpertiseOption(build) {
  let selectedChoices = skillChoices(build.classOptions.classSkills);
  if hasExpertiseOption(build.class) then
    [panel("Expertise", [
      vp([vtext("Choose which selected class skills receive expertise.")]),
      field("First expertise", vselect("expertise-one", selectedChoices, skillId(build.classOptions.expertiseSkillOne), fn v => SetExpertiseSkillOne { value = v })),
      field("Second expertise", vselect("expertise-two", selectedChoices, skillId(build.classOptions.expertiseSkillTwo), fn v => SetExpertiseSkillTwo { value = v }))
    ])]
  else
    [];
}

function classOptionViews(build) {
  [viewClassSkillSelector(build)] + viewFightingStyleOption(build) + viewClericOrderOption(build) + viewDruidOrderOption(build) + viewExpertiseOption(build);
}

function viewBuilderClassOptions(model, view) {
  let build = model.character.build;
  panel("Step 3 — Class Options", [
    vp([vtext("Choose class-specific setup options. These choices are durable build data and feed the computed rules/projection.")]),
    row("Class", className(build.class))
  ] + classOptionViews(build) + [
    vfieldBlock("Selected class options", [
      row("Options", classOptionsLine(build.class, build.classOptions))
    ]),
    vdivClass(["button-row"], [
      vbutton("Back", backBeforeClassOptionsMessage(build)),
      vbutton("Next: Abilities", GoAbilities)
    ])
  ]);
}

function viewBuilderSpeciesOptions(model, view) {
  let build = model.character.build;
  panel("Step 2 — Species Options", [
    vp([vtext("Some species have additional setup choices. Species without options skip this page automatically.")]),
    row("Species", speciesName(build.species))
  ] + speciesOptionViews(build) + [
    vdivClass(["button-row"], [
      vbutton("Back: Identity", GoIdentity),
      vbutton("Next: Class Options", GoClassOptions)
    ])
  ]);
}

function viewBuilderIdentity(model, view) {
  let catalog = model.catalog;
  let build = model.character.build;
  let speciesId = currentSpeciesId(build.species);
  let classId = currentClassId(build.class);
  let backgroundId = currentBackgroundId(build.background);
  panel("Step 1 — Identity", [
    vp([vtext("Choose the durable facts that define the character. The sheet updates from these choices instead of storing derived values.")]),
    field("Name", vinput("name", view.name, "Character name", fn v => SetName { value = v })),
    field("Gender", genderSelector(build)),
    row("Name generator", nameSuggestionStatus(build)),
    vdivClass(["button-row"], [vbutton("Suggest name", SuggestName)]),
    field("Species", vselect("species", speciesChoices(catalog), speciesId, fn v => SelectSpecies { value = v })),
    field("Class", vselect("class", classChoices(catalog), classId, fn v => SelectClass { value = v })),
    field("Background", vselect("background", backgroundChoices(catalog), backgroundId, fn v => SelectBackground { value = v })),
    field("Level", vinput("level", __str__(build.level), "level", fn v => SetLevel { value = v })),
    vdivClass(["button-row"], [vbutton("Next", nextAfterIdentityMessage(build))])
  ]);
}


function abilityChoice(ability) {
  choice(abilityId(ability), abilityShort(ability) + " — " + abilityName(ability));
}

function allAbilityChoices() {
  [abilityChoice(a) for a <- abilities];
}

function backgroundBonusChoices(background) {
  [abilityChoice(a) for a <- backgroundAbilityChoices(background)];
}

function abilityMethodChoices() {
  [
    choice("manual", "Manual entry"),
    choice("standard-array", "Standard array"),
    choice("point-buy", "Point buy"),
    choice("roll", "Roll scores")
  ];
}

function backgroundBonusModeChoices() {
  [
    choice("plus-two-plus-one", "+2 / +1"),
    choice("plus-one-plus-one-plus-one", "+1 / +1 / +1")
  ];
}

function rollModeChoices() {
  [
    choice("4d6-drop-lowest", "4d6 drop lowest"),
    choice("4d6-reroll-ones", "4d6 drop lowest, reroll 1s"),
    choice("4d6-reroll-one-two", "4d6 drop lowest, reroll 1s and 2s"),
    choice("3d6", "3d6 straight"),
    choice("2d6-plus-6", "2d6 + 6")
  ];
}

function scoreOption(score) {
  vchoice(__str__(score), __str__(score), "", OptionAvailable);
}

function standardScoreUsed(selection, scoreText) {
  selection.standardStrength == scoreText ||
  selection.standardDexterity == scoreText ||
  selection.standardConstitution == scoreText ||
  selection.standardIntelligence == scoreText ||
  selection.standardWisdom == scoreText ||
  selection.standardCharisma == scoreText;
}

function standardScoreState(selection, scoreText) {
  if selection.standardSelectedScore == scoreText then
    OptionSelected
  else if standardScoreUsed(selection, scoreText) then
    OptionDisabled
  else
    OptionAvailable;
}

function standardScoreChoice(selection, score) {
  let value = __str__(score);
  vchoice(value, value, "", standardScoreState(selection, value));
}

function standardArrayOptions(selection) {
  [standardScoreChoice(selection, score) for score <- standardArrayValues()];
}

function assignedScoreLabel(value) {
  value == "" ? "—" : value;
}

function standardAbilityOptionState(selection, value) {
  selection.standardSelectedScore == "" ? OptionDisabled : OptionAvailable;
}

function standardAbilityChoice(label, value) {
  vchoice(value, label, "", OptionAvailable);
}

function standardAbilityButton(name, label, assigned, msg, selection) {
  let text = label + " " + assignedScoreLabel(assigned);
  let state = standardAbilityOptionState(selection, assigned);
  vchoiceGroup(name, [vchoice(name, text, "", state)], fn v => msg);
}

function pointBuyAdjust(label, score, decreaseMsg, increaseMsg) {
  vdivClass(["point-buy-control"], [
    vspan([vtext(label + " " + __str__(score))]),
    vbutton("−", decreaseMsg),
    vbutton("+", increaseMsg),
    vspan([vtext("cost " + __str__(pointBuyCost(score)))])
  ]);
}

function pointBuyCostField(label, score) {
  row(label, __str__(score) + " costs " + __str__(pointBuyCost(score)));
}

function backgroundBonusTertiaryField(selection, choices) {
  if selection.backgroundBonusMode == "plus-one-plus-one-plus-one" then
    [field("Third +1", vselect("bg-bonus-third", choices, selection.backgroundBonusTertiary, fn v => SetBackgroundBonusTertiary { value = v }))]
  else
    [];
}

function viewBackgroundBonusBuilder(model) {
  let selection = model.selection;
  let background = model.character.build.background;
  let choices = backgroundBonusChoices(background);
  let tertiary = backgroundBonusTertiaryField(selection, choices);
  panel("Background ability bonuses", [
    vp([vtext("Choose how this background's ability score bonuses are assigned. Changes are applied automatically to the current scores.")]),
    row("Available", backgroundAbilityLine(background)),
    field("Mode", vselect("background-bonus-mode", backgroundBonusModeChoices(), selection.backgroundBonusMode, fn v => SetBackgroundBonusMode { value = v })),
    field("Primary", vselect("bg-bonus-primary", choices, selection.backgroundBonusPrimary, fn v => SetBackgroundBonusPrimary { value = v })),
    field("Secondary", vselect("bg-bonus-secondary", choices, selection.backgroundBonusSecondary, fn v => SetBackgroundBonusSecondary { value = v }))
  ] + tertiary);
}

function viewStandardArrayBuilder(model) {
  let selection = model.selection;
  panel("Standard array", [
    vp([vtext("Choose an unassigned score, then choose the ability that receives it. Assigned scores become unavailable until that ability is changed.")]),
    field("Scores", vchoiceGroup("standard-score", standardArrayOptions(selection), fn v => SelectStandardScore { value = v })),
    field("Abilities", vdivClass(["choice-grid"], [
      standardAbilityButton("assign-str", "STR", selection.standardStrength, AssignStandardStrength, selection),
      standardAbilityButton("assign-dex", "DEX", selection.standardDexterity, AssignStandardDexterity, selection),
      standardAbilityButton("assign-con", "CON", selection.standardConstitution, AssignStandardConstitution, selection),
      standardAbilityButton("assign-int", "INT", selection.standardIntelligence, AssignStandardIntelligence, selection),
      standardAbilityButton("assign-wis", "WIS", selection.standardWisdom, AssignStandardWisdom, selection),
      standardAbilityButton("assign-cha", "CHA", selection.standardCharisma, AssignStandardCharisma, selection)
    ])),
    vdivClass(["button-row"], [vbutton("Use default assignment", ApplyStandardArray)])
  ]);
}

function viewPointBuyBuilder(model) {
  let scores = model.character.build.scores;
  panel("Point buy", [
    vp([vtext("Use +/− to adjust point-buy scores from 8 to 15. Background bonuses stay applied automatically.")]),
    pointBuyAdjust("STR", scores.strength, DecreaseStrength, IncreaseStrength),
    pointBuyAdjust("DEX", scores.dexterity, DecreaseDexterity, IncreaseDexterity),
    pointBuyAdjust("CON", scores.constitution, DecreaseConstitution, IncreaseConstitution),
    pointBuyAdjust("INT", scores.intelligence, DecreaseIntelligence, IncreaseIntelligence),
    pointBuyAdjust("WIS", scores.wisdom, DecreaseWisdom, IncreaseWisdom),
    pointBuyAdjust("CHA", scores.charisma, DecreaseCharisma, IncreaseCharisma),
    vfieldBlock("Point buy budget", [
      row("Budget", pointBuyStatus(scores))
    ]),
    vdivClass(["button-row"], [vbutton("Reset point buy", ResetPointBuy)])
  ]);
}

function viewRollBuilder(model) {
  let selection = model.selection;
  panel("Roll ability scores", [
    vp([vtext("Roll all six scores using the selected method. Rolls use the runtime random library instead of a known seed.")]),
    field("Roll mode", vselect("roll-mode", rollModeChoices(), selection.rollMode, fn v => SetRollMode { value = v })),
    row("Last roll", selection.rollSummary),
    vdivClass(["button-row"], [vbutton("Roll ability scores", RollAbilityScores)])
  ]);
}

function viewAbilityMethodPanel(model) {
  let method = model.selection.abilityMethod;
  if method == "standard-array" then
    viewStandardArrayBuilder(model)
  else if method == "point-buy" then
    viewPointBuyBuilder(model)
  else if method == "roll" then
    viewRollBuilder(model)
  else
    panel("Manual entry", [vp([vtext("Edit the six scores directly. This is also useful after applying a standard array, point buy reset, background bonuses, or rolled scores.")])]);
}

function viewBuilderAbilities(model, view) {
  let scores = model.character.build.scores;
  panel("Step 4 — Ability Scores", [
    vp([vtext("Choose an ability-score workflow, then edit the six scores. Modifiers, skills, saves, AC, initiative, and carrying capacity are derived from the resulting build.")]),
    field("Method", vselect("ability-method", abilityMethodChoices(), model.selection.abilityMethod, fn v => SetAbilityMethod { value = v })),
    vdivClass(["scores"], [
      field("STR", scoreInput("strength", scores.strength, fn v => SetStrength { value = v })),
      field("DEX", scoreInput("dexterity", scores.dexterity, fn v => SetDexterity { value = v })),
      field("CON", scoreInput("constitution", scores.constitution, fn v => SetConstitution { value = v })),
      field("INT", scoreInput("intelligence", scores.intelligence, fn v => SetIntelligence { value = v })),
      field("WIS", scoreInput("wisdom", scores.wisdom, fn v => SetWisdom { value = v })),
      field("CHA", scoreInput("charisma", scores.charisma, fn v => SetCharisma { value = v }))
    ]),
    vfieldBlock("Derived preview", [
      row("Initiative", formatMod(view.initiativeMod)),
      row("Passive Perception", __str__(view.passivePerception)),
      row("Carrying", __str__(view.carryingCapacity)),
      row("Point buy", pointBuyStatus(scores))
    ]),
    viewAbilityMethodPanel(model),
    viewBackgroundBonusBuilder(model),
    vdivClass(["button-row"], [
      vbutton("Back: Class Options", GoClassOptions),
      vbutton("Next: Equipment", GoEquipment)
    ])
  ]);
}

function viewBuilderEquipment(model, view) {
  panel("Step 5 — Equipment", [
    vp([vtext("Add equipment from the active content catalog. Equipment contributes to the computed sheet through rules and projections.")]),
    field("Shield", vcheckbox("shield", model.character.build.loadout.hasShield, "Equipped", fn v => ToggleShield { value = v })),
    viewEquipmentPicker(model, view),
    viewEquippedEquipment(model),
    vdivClass(["button-row"], [
      vbutton("Back: Abilities", GoAbilities),
      vbutton("Next: Review", GoReview)
    ])
  ]);
}

function viewBuilderReview(model, context, view) {
  panel("Step 6 — Review", [
    vp([vtext("Review the computed character before using the play tools. This page is read-only except for returning to earlier steps.")]),
    vfieldBlock("Summary", [
      row("Name", view.name),
      row("Level", __str__(view.level)),
      row("Species", view.speciesName),
      row("Species options", speciesOptionsLine(model.character.build.species, model.character.build.speciesOptions)),
      row("Class", view.className),
      row("Class options", classOptionsLine(model.character.build.class, model.character.build.classOptions)),
      row("Background", view.backgroundName)
    ]),
    vfieldBlock("Combat preview", [
      row("HP", __str__(view.currentHp) + "/" + __str__(view.hitPointMax)),
      row("AC", __str__(view.armorClass)),
      row("Initiative", formatMod(view.initiativeMod)),
      row("Proficiency", formatMod(view.proficiencyBonus))
    ]),
    vdefinitionList("Traits", traitDefinitionsForView(view.traits)),
    vdefinitionList("Feats", featDefinitionsForView(view.feats)),
    vdivClass(["button-row"], [
      vbutton("Back: Equipment", GoEquipment),
      vbutton("Go to Play", SetActiveTab { value = "play" })
    ])
  ]);
}

function viewStructuredBuilder(model, context, view) {
  let step = model.selection.builderStep;
  panel("Structured builder", [
    builderStepNav(model.selection, model.character.build),
    row("Current step", builderStepLabel(step))
  ]);
}

function viewBuilderStep(model, context, view) {
  match model.selection.builderStep with
  | IdentityStep -> [viewBuilderIdentity(model, view)]
  | SpeciesOptionsStep -> [viewBuilderSpeciesOptions(model, view)]
  | ClassOptionsStep -> [viewBuilderClassOptions(model, view)]
  | AbilitiesStep -> [viewBuilderAbilities(model, view)]
  | EquipmentStep -> [viewBuilderEquipment(model, view)]
  | ReviewStep -> [viewBuilderReview(model, context, view)];
}

function viewBuilder(model, view) {
  let catalog = model.catalog;
  let build = model.character.build;
  let scores = build.scores;
  let speciesId = currentSpeciesId(build.species);
  let classId = currentClassId(build.class);
  let backgroundId = currentBackgroundId(build.background);
  panel("Builder", [
    field("Name", vinput("name", view.name, "Character name", fn v => SetName { value = v })),
    field("Gender", genderSelector(build)),
    row("Name generator", nameSuggestionStatus(build)),
    vdivClass(["button-row"], [vbutton("Suggest name", SuggestName)]),
    field("Species", vselect("species", speciesChoices(catalog), speciesId, fn v => SelectSpecies { value = v })),
    field("Class", vselect("class", classChoices(catalog), classId, fn v => SelectClass { value = v })),
    field("Background", vselect("background", backgroundChoices(catalog), backgroundId, fn v => SelectBackground { value = v })),
    field("Level", vinput("level", __str__(build.level), "level", fn v => SetLevel { value = v })),
    vdivClass(["scores"], [
      field("STR", scoreInput("strength", scores.strength, fn v => SetStrength { value = v })),
      field("DEX", scoreInput("dexterity", scores.dexterity, fn v => SetDexterity { value = v })),
      field("CON", scoreInput("constitution", scores.constitution, fn v => SetConstitution { value = v })),
      field("INT", scoreInput("intelligence", scores.intelligence, fn v => SetIntelligence { value = v })),
      field("WIS", scoreInput("wisdom", scores.wisdom, fn v => SetWisdom { value = v })),
      field("CHA", scoreInput("charisma", scores.charisma, fn v => SetCharisma { value = v }))
    ]),
    field("Shield", vcheckbox("shield", build.loadout.hasShield, "Equipped", fn v => ToggleShield { value = v })),
    vdivClass(["actions-row"], [vbutton("Reset sample", ResetSample)])
  ]);
}

function viewPlayEditor(model, context, projected) {
  let health = healthView(model.character);
  let resources = characterResources(model.character, context.rules, model.turn);
  panel("Play state", [
    row("Health", health.line),
    row("Conditions", conditionLine(model.character)),
    row("Resources", listText(resourceLines(resources))),
    field("Notes", vinput("notes", model.character.state.notes, "table notes", fn v => SetNotesText { value = v })),
    field("Damage", vinput("damage", model.damageText, "damage", fn v => SetDamageText { value = v })),
    vdivClass(["button-row"], [vbutton("Take damage", ApplyDamage)]),
    field("Healing", vinput("healing", model.healingText, "healing", fn v => SetHealingText { value = v })),
    vdivClass(["button-row"], [vbutton("Heal", ApplyHealing)]),
    field("Temp HP", vinput("temp-hp", model.tempText, "temp HP", fn v => SetTempText { value = v })),
    vdivClass(["button-row"], [vbutton("Gain temp HP", ApplyTempHp)]),
    vdivClass(["button-row"], [
      vbutton("Use Sneak Attack", UseSneakAttack),
      vbutton("Start turn", StartTurn),
      vbutton("Short rest", ShortRestMsg),
      vbutton("Long rest", LongRestMsg)
    ]),
    viewConditionsEditor(model.character)
  ]);
}

function viewStatusPanel(model, context) {
  let health = healthView(model.character);
  let resources = characterResources(model.character, context.rules, model.turn);
  panel("Status", [
    vfieldBlock("Current state", [
      row("Health", health.line),
      row("Conditions", conditionLine(model.character)),
      row("Resources", listText(resourceLines(resources)))
    ]),
    viewConditionsEditor(model.character)
  ]);
}

function editorActionViews(actions) {
  if length(actions) == 0 then
    [vdivClass(["catalog-item"], [vspan([vtext("No actions available")])])]
  else
    [
      vdivClass(["action-card"], [
        vdivClass(["action-head"], [
          vspan([vtext(a.name)]),
          vspan([vtext(actionTimingName(a.timing))])
        ]),
        row("Source", a.source),
        row("Kind", actionKindName(a.kind)),
        row("Attack", a.attackBonus == 0 ? "—" : formatMod(a.attackBonus)),
        row("Damage", a.damageText == "" ? "—" : a.damageText),
        vp([vtext(a.description)])
      ])
      for a <- actions
    ];
}

function viewActionsPanel(character, context) {
  let actions = characterActions(character, context.rules);
  panel("Actions", [
    row("Available", __str__(length(actions))),
    vdivClass(["action-list"], editorActionViews(actions))
  ]);
}

function viewSheet(view) {
  let hpLine = __str__(view.currentHp) + "/" + __str__(view.hitPointMax) + " HP";
  let tempLine = __str__(view.temporaryHp) + " temp";
  let levelLine = "Level " + __str__(view.level) + " " + view.speciesName + " " + view.className + ", " + view.backgroundName;
  panel("Computed sheet", [
    vh(3, view.name),
    vp([vtext(levelLine)]),
    vfieldBlock("Core", [
      row("Currency", view.currencyText),
      row("HP", hpLine + " + " + tempLine),
      row("AC", __str__(view.armorClass)),
      row("Initiative", formatMod(view.initiativeMod)),
      row("Proficiency", formatMod(view.proficiencyBonus)),
      row("Passive Perception", __str__(view.passivePerception)),
      row("Carrying", __str__(view.carryingCapacity))
    ]),
    vfieldBlock("Proficiencies", [
      row("Saving Throws", listText(view.savingThrows)),
      row("Skills", listText(view.backgroundSkills)),
      row("Tools", listText(view.backgroundTools))
    ]),
    vdefinitionList("Traits", traitDefinitionsForView(view.traits)),
    vdefinitionList("Feats", featDefinitionsForView(view.feats)),
    vfieldBlock("Equipment", [
      row("Equipment", listText(view.equipment)),
      row("Weapons", listText(weaponLines(view.weapons))),
      row("Rule Bonuses", listText(bonusLines(view.bonuses)))
    ])
  ]);
}

function activeEditorViews(model, context, projected) {
  let tab = model.selection.activeTab;
  if tab == "builder" then
    [viewStructuredBuilder(model, context, projected)] + viewBuilderStep(model, context, projected)
  else if tab == "play" then
    [viewPlayEditor(model, context, projected)]
  else
    [viewSheet(projected)];
}

function styleBlock() {
  vcontent(RawHtml { "<style>:root {  --cf-bg: #020617;  --cf-bg-soft: #0f172a;  --cf-surface: rgba(15, 23, 42, 0.92);  --cf-surface-raised: rgba(30, 41, 59, 0.94);  --cf-surface-subtle: rgba(15, 23, 42, 0.72);  --cf-border: #334155;  --cf-border-strong: #475569;  --cf-text: #e2e8f0;  --cf-text-muted: #94a3b8;  --cf-text-soft: #cbd5e1;  --cf-accent: #f97316;  --cf-accent-hover: #fb923c;  --cf-accent-soft: rgba(249, 115, 22, 0.14);  --cf-accent-border: rgba(251, 146, 60, 0.42);  --cf-danger: #f43f5e;  --cf-radius: 18px;  --cf-radius-sm: 12px;  --cf-shadow: 0 20px 45px rgba(0, 0, 0, 0.28);  --cf-shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.18);}#pfun-output {  white-space: normal !important;  line-height: 1.45;}* {  box-sizing: border-box;}body {  margin: 0;  background:    radial-gradient(circle at top left, rgba(249, 115, 22, 0.22), transparent 34rem),    radial-gradient(circle at bottom right, rgba(30, 64, 175, 0.16), transparent 32rem),    var(--cf-bg);  color: var(--cf-text);  font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif;}body::-webkit-scrollbar,#pfun-output *::-webkit-scrollbar {  width: 8px;  height: 8px;}body::-webkit-scrollbar-track,#pfun-output *::-webkit-scrollbar-track {  background: var(--cf-bg-soft);}body::-webkit-scrollbar-thumb,#pfun-output *::-webkit-scrollbar-thumb {  background: var(--cf-border);  border-radius: 999px;}body::-webkit-scrollbar-thumb:hover,#pfun-output *::-webkit-scrollbar-thumb:hover {  background: var(--cf-border-strong);}.app {  max-width: 1500px;  margin: 0 auto;  padding: 28px;  color: var(--cf-text);}.hero {  position: sticky;  top: 0;  z-index: 5;  margin: -28px -28px 22px;  padding: 24px 28px 18px;  border-bottom: 1px solid rgba(51, 65, 85, 0.7);  background: linear-gradient(180deg, rgba(2, 6, 23, 0.97), rgba(2, 6, 23, 0.82));  backdrop-filter: blur(16px);}.hero h1 {  margin: 0;  font-size: clamp(2rem, 4vw, 3.25rem);  line-height: 1;  letter-spacing: -0.055em;  color: #f8fafc;}.hero p {  max-width: 860px;  margin: 10px 0 0;  color: var(--cf-text-muted);}.layout {  display: grid;  grid-template-columns: minmax(230px, 280px) minmax(380px, 1fr) minmax(380px, 1fr);  gap: 20px;  align-items: start;}.sidebar,.middle-pane,.right-pane {  min-width: 0;  display: flex;  flex-direction: column;  gap: 20px;}.pf-card {  position: relative;  display: block;  overflow: visible;  padding: 18px;  border: 1px solid rgba(51, 65, 85, 0.92);  border-radius: var(--cf-radius);  background: linear-gradient(180deg, var(--cf-surface-raised), var(--cf-surface));  box-shadow: var(--cf-shadow-soft);}.pf-card::before {  content: \"\";  position: absolute;  inset: 0;  pointer-events: none;  border-radius: inherit;  border-top: 1px solid rgba(255, 255, 255, 0.08);}.pf-card h2 {  margin: 0 0 14px;  font-size: 1rem;  letter-spacing: 0.08em;  text-transform: uppercase;  color: #f8fafc;}.pf-card h3 {  margin: 18px 0 8px;  font-size: 0.82rem;  letter-spacing: 0.08em;  text-transform: uppercase;  color: var(--cf-text-soft);}.field {  display: grid;  grid-template-columns: 118px minmax(0, 1fr);  gap: 12px;  align-items: center;  margin: 10px 0;}.field-label {  font-size: 0.78rem;  font-weight: 800;  letter-spacing: 0.07em;  text-transform: uppercase;  color: var(--cf-text-muted);}.scores {  display: grid;  grid-template-columns: 1fr 1fr;  gap: 8px 14px;  margin: 14px 0;  padding: 12px;  border: 1px solid rgba(51, 65, 85, 0.74);  border-radius: var(--cf-radius-sm);  background: rgba(2, 6, 23, 0.28);}.scores .field {  grid-template-columns: 48px minmax(0, 1fr);  margin: 0;}.pf-field {  display: flex;  justify-content: space-between;  gap: 18px;  align-items: flex-start;  padding: 9px 0;  border-bottom: 1px solid rgba(51, 65, 85, 0.72);}.pf-field:last-child {  border-bottom: 0;}.pf-field-label {  font-size: 0.76rem;  font-weight: 800;  letter-spacing: 0.07em;  text-transform: uppercase;  color: var(--cf-text-muted);}.pf-field-value {  text-align: right;  color: #f8fafc;  overflow-wrap: anywhere;}.pf-field-block {  margin: 12px 0;  padding: 12px;  border: 1px solid rgba(51, 65, 85, 0.74);  border-radius: var(--cf-radius-sm);  background: rgba(2, 6, 23, 0.28);}.pf-field-block h3 {  margin-top: 0;}.builder-steps {  display: grid;  grid-template-columns: repeat(4, minmax(0, 1fr));  gap: 8px;  margin: 10px 0 14px;}.builder-step button {  width: 100%;  min-height: 44px;}.builder-step.selected button {  background: linear-gradient(135deg, var(--cf-accent), #ea580c);  color: #111827;  border-color: var(--cf-accent-hover);  box-shadow: 0 0 0 3px var(--cf-accent-soft);}.actions-row,.button-row {  display: flex;  gap: 10px;  flex-wrap: wrap;  margin: 10px 0;}.character-list,.catalog-list,.action-list {  display: flex;  flex-direction: column;  gap: 9px;  margin-top: 10px;}.character-row button {  width: 100%;  justify-content: flex-start;  text-align: left;  background: rgba(15, 23, 42, 0.85);  color: var(--cf-text);  border-color: rgba(51, 65, 85, 0.9);}.character-row.selected button {  background: linear-gradient(135deg, var(--cf-accent), #ea580c);  color: #111827;  border-color: var(--cf-accent-hover);  box-shadow: 0 0 0 3px var(--cf-accent-soft);}.catalog-item,.action-card {  border: 1px solid rgba(51, 65, 85, 0.85);  border-radius: var(--cf-radius-sm);  background: var(--cf-surface-subtle);}.catalog-item {  display: flex;  justify-content: space-between;  gap: 12px;  align-items: center;  min-width: 0;  padding: 9px 11px;}.catalog-item span {  overflow-wrap: anywhere;}.action-card {  padding: 12px;}.action-head {  display: flex;  justify-content: space-between;  gap: 12px;  margin-bottom: 8px;  font-weight: 900;  color: #f8fafc;}.status {  margin-top: 12px;  color: var(--cf-accent-hover);  font-weight: 700;}input,select,button {  max-width: 100%;  padding: 9px 11px;  border-radius: 10px;  border: 1px solid rgba(71, 85, 105, 0.9);  background: #020617;  color: var(--cf-text);  font: inherit;}input::placeholder {  color: #64748b;}input:focus,select:focus,button:focus-visible {  outline: none;  border-color: var(--cf-accent-hover);  box-shadow: 0 0 0 3px var(--cf-accent-soft);}button {  cursor: pointer;  font-weight: 800;  background: linear-gradient(180deg, #1e293b, #0f172a);  color: var(--cf-text);  transition: transform 0.12s ease, border-color 0.12s ease, background 0.12s ease;}button:hover {  transform: translateY(-1px);  border-color: var(--cf-accent-border);  background: linear-gradient(180deg, #334155, #1e293b);}.pf-option-group {  display: flex;  flex-wrap: wrap;  gap: 10px;  margin: 10px 0 14px;}.pf-option-button {  min-width: 96px;  min-height: 74px;  display: inline-flex;  flex-direction: column;  align-items: center;  justify-content: center;  gap: 6px;  padding: 12px 14px;  border: 1px solid rgba(71, 85, 105, 0.9);  border-radius: var(--cf-radius-sm);  background: linear-gradient(180deg, rgba(30, 41, 59, 0.92), rgba(15, 23, 42, 0.96));  color: var(--cf-text);  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);}.pf-option-button:hover {  border-color: var(--cf-accent-border);  background: linear-gradient(180deg, rgba(51, 65, 85, 0.96), rgba(30, 41, 59, 0.96));}.pf-option-button.pf-option-selected {  background: linear-gradient(135deg, var(--cf-accent), #ea580c);  color: #111827;  border-color: var(--cf-accent-hover);  box-shadow: 0 0 0 3px var(--cf-accent-soft), inset 0 0 0 2px rgba(255, 255, 255, 0.28);  transform: translateY(-1px);}.pf-option-icon {  display: block;  font-size: 1.4rem;  line-height: 1;}.pf-option-label {  display: block;  font-size: 0.78rem;  font-weight: 900;  letter-spacing: 0.06em;  text-transform: uppercase;}.pf-option-selected .pf-option-icon,.pf-option-selected .pf-option-label {  color: #111827;}.pf-option-button.pf-option-disabled {  opacity: 0.38;  cursor: not-allowed;  transform: none;  background: rgba(15, 23, 42, 0.55);  color: var(--cf-text-muted);}.pf-option-button.pf-option-disabled:hover {  transform: none;  border-color: rgba(71, 85, 105, 0.9);  background: rgba(15, 23, 42, 0.55);}.pf-option-button.pf-option-locked {  cursor: not-allowed;}.pf-option-caption {  display: block;  margin-top: 2px;  font-size: 0.68rem;  font-weight: 900;  letter-spacing: 0.05em;  text-transform: uppercase;  opacity: 0.82;}.pf-card .button-row > button:first-child,.pf-card .actions-row > button:first-child {  background: linear-gradient(135deg, var(--cf-accent), #ea580c);  color: #111827;  border-color: var(--cf-accent-hover);}label {  color: var(--cf-text-muted);  font-size: 0.85rem;  font-weight: 700;}@media (max-width: 1180px) {  .layout {    grid-template-columns: 1fr 1fr;  }  .sidebar {    grid-column: 1 / -1;  }}@media (max-width: 780px) {  .app {    padding: 18px;  }  .hero {    margin: -18px -18px 18px;    padding: 20px 18px 16px;  }  .layout {    grid-template-columns: 1fr;  }  .field {    grid-template-columns: 1fr;  }  .scores {    grid-template-columns: 1fr;  }}</style>" });
}

function view(model) {
  let context = contextForCharacter(model.catalog, model.character);
  let projected = projectCharacter(model.character, context);
  vdivClass(["app"], [
    styleBlock(),
    vdivClass(["hero"], [
      vh(1, "Character Forge / Pfun"),
      vp([vtext("Tiny TEA editor pass. Build, play state, resources, conditions, and editor state stay separate; the sheet is recomputed from pure functions.")]),
      vdivClass(["status"], [vtext(model.status)])
    ]),
    vdivClass(["layout"], [
      vdivClass(["sidebar"], [viewCharacterList(model), viewContentPacks(model), viewSaveLoad(model)]),
      vdivClass(["middle-pane"], [viewBuilderSelection(model)] + activeEditorViews(model, context, projected)),
      vdivClass(["right-pane"], [
        viewStatusPanel(model, context),
        viewActionsPanel(model.character, context),
        viewSheet(projected)
      ])
    ])
  ]);
}

