// Character Forge app UI/view helpers
//
// This module owns browser view construction only. It does not update
// character data, calculate rules, or manage documents.

import * from "$PFUN_HOME/lib/htmllib";
import * from "$PFUN_HOME/lib/viewlib";
import * from "../character/abilities";
import * from "../character/character";
import * from "../character/rules";
import * from "../content/content";
import * from "../content/contentpack";
import * from "../content/catalogops";
import * from "../character/buildops";
import * from "../character/stateops";
import * from "../character/context";
import * from "../character/resources";
import * from "../character/actions";
import * from "./appmodel";
import * from "./documentops";
import * from "./saveload";
import * from "../character/traits";
import * from "../character/feats";
import * from "../builder/abilitybuilder";
import * from "../builder/namegenerator";

// ── View helpers ──────────────────────────────────────────────────────────────

function panel(title, children) {
  vcard(title, children);
}

function row(label, value) {
  vfield(label, value);
}

function field(label, control) {
  vdivClass(["field"], [
    vdivClass(["field-label"], [vtext(label)]),
    control
  ]);
}

function scoreInput(name, value, msgFn) {
  vinput(name, __str__(value), "score", msgFn);
}

function listText(values) {
  length(values) == 0 ? "none" : join(values, ", ");
}

function weaponLines(weapons) {
  [w.line for w <- weapons];
}

function bonusLines(bonuses) {
  [b.line for b <- bonuses];
}

function traitDefinitionsForView(traits) {
  [vdefinition(t.name, t.kindName + " — " + t.source + ". " + t.description) for t <- traits];
}

function featDefinitionsForView(feats) {
  [vdefinition(f.name, f.kindName + ". " + f.summary) for f <- feats];
}

function resourceLines(resources) {
  [r.line for r <- resources];
}

function conditionLine(character) {
  let names = conditionNames(character);
  listText(names);
}

function conditionId(condition) {
  match condition with
  | Blinded -> "condition.blinded"
  | Charmed -> "condition.charmed"
  | Frightened -> "condition.frightened"
  | Grappled -> "condition.grappled"
  | Incapacitated -> "condition.incapacitated"
  | Invisible -> "condition.invisible"
  | Poisoned -> "condition.poisoned"
  | Prone -> "condition.prone"
  | Restrained -> "condition.restrained"
  | Stunned -> "condition.stunned"
  | Unconscious -> "condition.unconscious";
}

function conditionFromId(id) {
  if id == "condition.blinded" then
    Blinded
  else if id == "condition.charmed" then
    Charmed
  else if id == "condition.frightened" then
    Frightened
  else if id == "condition.grappled" then
    Grappled
  else if id == "condition.incapacitated" then
    Incapacitated
  else if id == "condition.invisible" then
    Invisible
  else if id == "condition.poisoned" then
    Poisoned
  else if id == "condition.restrained" then
    Restrained
  else if id == "condition.stunned" then
    Stunned
  else if id == "condition.unconscious" then
    Unconscious
  else
    Prone;
}

function conditionChoices() {
  [
    choice("condition.blinded", "Blinded"),
    choice("condition.charmed", "Charmed"),
    choice("condition.frightened", "Frightened"),
    choice("condition.grappled", "Grappled"),
    choice("condition.incapacitated", "Incapacitated"),
    choice("condition.invisible", "Invisible"),
    choice("condition.poisoned", "Poisoned"),
    choice("condition.prone", "Prone"),
    choice("condition.restrained", "Restrained"),
    choice("condition.stunned", "Stunned"),
    choice("condition.unconscious", "Unconscious")
  ];
}

function conditionAddButton(c) {
  catalogItemButton(c.label, AddConditionById { c.value });
}

function activeConditionView(condition) {
  vdivClass(["catalog-item"], [
    vspan([vtext(conditionName(condition))]),
    vbutton("Remove", RemoveConditionById { conditionId(condition) })
  ]);
}

function activeConditionViews(character) {
  if length(character.state.conditions) == 0 then
    [vdivClass(["catalog-item"], [vspan([vtext("No active conditions")])])]
  else
    [activeConditionView(c) for c <- character.state.conditions];
}

function viewConditionsEditor(character) {
  panel("Conditions", [
    row("Active", conditionLine(character)),
    vh(3, "Active conditions"),
    vdivClass(["catalog-list"], activeConditionViews(character)),
    vh(3, "Add condition"),
    vdivClass(["catalog-list"], [conditionAddButton(c) for c <- conditionChoices()])
  ]);
}


function tabChoices() {
  [
    choice("builder", "Builder"),
    choice("play", "Play"),
    choice("sheet", "Sheet")
  ];
}

function builderStepValue(step) {
  match step with
  | IdentityStep -> "identity"
  | SpeciesOptionsStep -> "species-options"
  | ClassOptionsStep -> "class-options"
  | AbilitiesStep -> "abilities"
  | EquipmentStep -> "equipment"
  | ReviewStep -> "review";
}

function builderStepChoices() {
  [
    choice("identity", "1. Identity"),
    choice("species-options", "2. Species Options"),
    choice("class-options", "3. Class Options"),
    choice("abilities", "4. Abilities"),
    choice("equipment", "5. Equipment"),
    choice("review", "6. Review")
  ];
}

function builderStepLabel(step) {
  match step with
  | IdentityStep -> "Identity"
  | SpeciesOptionsStep -> "Species Options"
  | ClassOptionsStep -> "Class Options"
  | AbilitiesStep -> "Abilities"
  | EquipmentStep -> "Equipment"
  | ReviewStep -> "Review";
}

function builderStepMessage(step) {
  match step with
  | IdentityStep -> GoIdentity
  | SpeciesOptionsStep -> GoSpeciesOptions
  | ClassOptionsStep -> GoClassOptions
  | AbilitiesStep -> GoAbilities
  | EquipmentStep -> GoEquipment
  | ReviewStep -> GoReview;
}

function nextAfterIdentityMessage(build) {
  if hasSpeciesOptions(build.species) then
    GoSpeciesOptions
  else
    GoClassOptions;
}

function backBeforeClassOptionsMessage(build) {
  if hasSpeciesOptions(build.species) then
    GoSpeciesOptions
  else
    GoIdentity;
}

function builderStepButton(current, step, label) {
  let classes = builderStepValue(current) == builderStepValue(step) ? ["builder-step", "selected"] : ["builder-step"];
  vdivClass(classes, [vbutton(label, builderStepMessage(step))]);
}

function speciesOptionNavButtons(selection, build) {
  if hasSpeciesOptions(build.species) then
    [builderStepButton(selection.builderStep, SpeciesOptionsStep, "2 Species Options")]
  else
    [];
}

function builderStepNav(selection, build) {
  vdivClass(["builder-steps"], [
    builderStepButton(selection.builderStep, IdentityStep, "1 Identity")
  ] + speciesOptionNavButtons(selection, build) + [
    builderStepButton(selection.builderStep, ClassOptionsStep, "3 Class Options"),
    builderStepButton(selection.builderStep, AbilitiesStep, "4 Abilities"),
    builderStepButton(selection.builderStep, EquipmentStep, "5 Equipment"),
    builderStepButton(selection.builderStep, ReviewStep, "6 Review")
  ]);
}

function equipmentCategoryChoices() {
  [
    choice("weapons", "Weapons"),
    choice("armor", "Armor"),
    choice("tools", "Tools"),
    choice("gear", "Gear")
  ];
}


function catalogItemButton(label, msg) {
  vdivClass(["catalog-item"], [
    vspan([vtext(label)]),
    vbutton("Add", msg)
  ]);
}

function textMatches(search, value) {
  if search == "" then
    true
  else {
    let found = findSlice(value, search);
    match found with
    | Some m -> true
    | None -> false;
  }
}

function contentMatches(search, id, name) {
  textMatches(search, name) || textMatches(search, id);
}

function filteredWeapons(catalog, search) {
  filter(fn d => contentMatches(search, d.id, d.name), catalog.weapons);
}

function filteredArmor(catalog, search) {
  filter(fn d => contentMatches(search, d.id, d.name), catalog.armor);
}

function filteredTools(catalog, search) {
  filter(fn d => contentMatches(search, d.id, d.name), catalog.tools);
}

function filteredGear(catalog, search) {
  filter(fn d => contentMatches(search, d.id, d.name), catalog.gear);
}

function pickerCategoryButton(active, id, label, count) {
  let classes = active == id ? ["character-row", "selected"] : ["character-row"];
  let text = label + " (" + __str__(count) + ")";
  vdivClass(classes, [vbutton(text, SetEquipmentCategory { id })]);
}

function equipmentCategoryBrowser(model) {
  let active = model.selection.equipmentCategory;
  let search = model.selection.equipmentSearch;
  vdivClass(["character-list"], [
    pickerCategoryButton(active, "weapons", "Weapons", length(filteredWeapons(model.catalog, search))),
    pickerCategoryButton(active, "armor", "Armor", length(filteredArmor(model.catalog, search))),
    pickerCategoryButton(active, "tools", "Tools", length(filteredTools(model.catalog, search))),
    pickerCategoryButton(active, "gear", "Gear", length(filteredGear(model.catalog, search)))
  ]);
}

function weaponDefinitionCard(def) {
  vdivClass(["action-card"], [
    vdivClass(["action-head"], [
      vspan([vtext(def.name)]),
      vspan([vtext(sourceName(def.source))])
    ]),
    vfieldBlock("Weapon", [
      row("ID", def.id),
      row("Ability", abilityShort(def.ability)),
      row("Damage", def.damage),
      row("Model", weaponName(def.weapon))
    ]),
    vdivClass(["button-row"], [vbutton("Add weapon", AddWeaponById { def.id })])
  ]);
}

function armorDefinitionCard(def) {
  vdivClass(["action-card"], [
    vdivClass(["action-head"], [
      vspan([vtext(def.name)]),
      vspan([vtext(sourceName(def.source))])
    ]),
    vfieldBlock("Armor", [
      row("ID", def.id),
      row("Base AC", __str__(def.baseAc)),
      row("Dex limit", def.dexLimit > 20 ? "none" : __str__(def.dexLimit)),
      row("Model", armorName(def.armor))
    ]),
    vdivClass(["button-row"], [vbutton("Equip armor", AddArmorById { def.id })])
  ]);
}

function toolDefinitionCard(def) {
  vdivClass(["action-card"], [
    vdivClass(["action-head"], [
      vspan([vtext(def.name)]),
      vspan([vtext(sourceName(def.source))])
    ]),
    vfieldBlock("Tool", [
      row("ID", def.id),
      row("Model", toolName(def.tool))
    ]),
    vdivClass(["button-row"], [vbutton("Add tool", AddToolById { def.id })])
  ]);
}

function gearDefinitionCard(def) {
  vdivClass(["action-card"], [
    vdivClass(["action-head"], [
      vspan([vtext(def.name)]),
      vspan([vtext(sourceName(def.source))])
    ]),
    vfieldBlock("Gear", [
      row("ID", def.id),
      row("Model", gearName(def.gear))
    ]),
    vdivClass(["button-row"], [vbutton("Add gear", AddGearById { def.id })])
  ]);
}

function noPickerResults() {
  [vdivClass(["catalog-item"], [vspan([vtext("No matching content")])])];
}

function weaponPickerResults(catalog, search) {
  let defs = filteredWeapons(catalog, search);
  length(defs) == 0 ? noPickerResults() : [weaponDefinitionCard(d) for d <- defs];
}

function armorPickerResults(catalog, search) {
  let defs = filteredArmor(catalog, search);
  length(defs) == 0 ? noPickerResults() : [armorDefinitionCard(d) for d <- defs];
}

function toolPickerResults(catalog, search) {
  let defs = filteredTools(catalog, search);
  length(defs) == 0 ? noPickerResults() : [toolDefinitionCard(d) for d <- defs];
}

function gearPickerResults(catalog, search) {
  let defs = filteredGear(catalog, search);
  length(defs) == 0 ? noPickerResults() : [gearDefinitionCard(d) for d <- defs];
}

function equipmentPickerResults(model) {
  let category = model.selection.equipmentCategory;
  let search = model.selection.equipmentSearch;
  if category == "weapons" then
    weaponPickerResults(model.catalog, search)
  else if category == "armor" then
    armorPickerResults(model.catalog, search)
  else if category == "tools" then
    toolPickerResults(model.catalog, search)
  else
    gearPickerResults(model.catalog, search);
}

function equipmentPickerTitle(category) {
  if category == "weapons" then
    "Add weapon"
  else if category == "armor" then
    "Equip armor"
  else if category == "tools" then
    "Add tool"
  else
    "Add gear";
}

function viewEquipmentPicker(model, view) {
  let selection = model.selection;
  panel("Equipment picker", [
    vp([vtext("Browse catalog content by category. Search matches names or stable IDs; adding an item updates the build, and the sheet recomputes from the projected character.")]),
    field("Search", vinput("equipment-search-main", selection.equipmentSearch, "search equipment", fn v => SetEquipmentSearch { value = v })),
    vfieldBlock("Current loadout", [
      row("Equipment", listText(view.equipment)),
      row("Active category", equipmentPickerTitle(selection.equipmentCategory))
    ]),
    vh(3, "Categories"),
    equipmentCategoryBrowser(model),
    vh(3, equipmentPickerTitle(selection.equipmentCategory)),
    vdivClass(["action-list"], equipmentPickerResults(model))
  ]);
}

function editorEquippedWeaponViews(weapons) {
  if length(weapons) == 0 then
    [vdivClass(["catalog-item"], [vspan([vtext("No weapons equipped")])])]
  else
    [
      vdivClass(["catalog-item"], [
        vspan([vtext(weaponName(w))]),
        vbutton("Remove", RemoveWeaponById { weaponId(w) })
      ])
      for w <- weapons
    ];
}

function editorEquippedArmorViews(armor) {
  if length(armor) == 0 then
    [vdivClass(["catalog-item"], [vspan([vtext("No armor equipped")])])]
  else
    [
      vdivClass(["catalog-item"], [
        vspan([vtext(armorName(a))]),
        vbutton("Clear", ClearArmorMsg)
      ])
      for a <- armor
    ];
}

function editorEquippedToolViews(tools) {
  if length(tools) == 0 then
    [vdivClass(["catalog-item"], [vspan([vtext("No tools added")])])]
  else
    [
      vdivClass(["catalog-item"], [
        vspan([vtext(toolName(t))]),
        vbutton("Remove", RemoveToolById { toolId(t) })
      ])
      for t <- tools
    ];
}

function editorEquippedGearViews(gear) {
  if length(gear) == 0 then
    [vdivClass(["catalog-item"], [vspan([vtext("No gear added")])])]
  else
    [
      vdivClass(["catalog-item"], [
        vspan([vtext(gearName(g))]),
        vbutton("Remove", RemoveGearById { gearId(g) })
      ])
      for g <- gear
    ];
}

function viewEquippedEquipment(model) {
  let loadout = model.character.build.loadout;
  panel("Equipped equipment", [
    vh(3, "Weapons"),
    vdivClass(["catalog-list"], editorEquippedWeaponViews(loadout.weapons)),
    vh(3, "Armor"),
    vdivClass(["catalog-list"], editorEquippedArmorViews(loadout.armor)),
    vh(3, "Tools"),
    vdivClass(["catalog-list"], editorEquippedToolViews(loadout.tools)),
    vh(3, "Gear"),
    vdivClass(["catalog-list"], editorEquippedGearViews(loadout.gear))
  ]);
}

function documentRow(model, doc) {
  let selected = doc.id == model.selectedId;
  let label = documentButtonLabel(doc);
  let classes = selected ? ["character-row", "selected"] : ["character-row"];
  vdivClass(classes, [
    vbutton(label, SelectCharacter { doc.id })
  ]);
}

function documentRows(model) {
  [documentRow(model, doc) for doc <- model.documents];
}

function viewCharacterList(model) {
  panel("Characters", [
    vdivClass(["button-row"], [
      vbutton("New", NewCharacter),
      vbutton("Duplicate", DuplicateSelected),
      vbutton("Delete", DeleteSelected)
    ]),
    vdivClass(["character-list"], documentRows(model))
  ]);
}


function exportFilename(model) {
  let name = model.character.build.identity.name;
  name + ".pfchar";
}

function exportDocumentText(model) {
  saveDocument(makeCharacterDocument(model.selectedId, model.character, model.turn));
}


function contentPackAction(pack) {
  if pack.enabled then "Disable" else "Enable";
}

function contentPackRow(pack) {
  vdivClass(["catalog-item"], [
    vspan([vtext(contentPackSummary(pack))]),
    vbutton(contentPackAction(pack), ToggleContentPack { pack.id })
  ]);
}

function contentEntryLabel(name, implemented) {
  if implemented then name else name + " ";
}

function speciesEntryDefinition(entry) {
  vdefinition(contentEntryLabel(entry.definition.name, entry.implemented), entry.definition.description);
}

function classEntryDefinition(entry) {
  let die = "Hit die d" + __str__(entry.hitDie);
  let primary = join(entry.primaryAbilities, ", ");
  let text = entry.definition.description + " " + die + ". Primary abilities: " + primary + ".";
  vdefinition(contentEntryLabel(entry.definition.name, entry.implemented), text);
}

function backgroundEntryDefinition(entry) {
  let abilities = join(entry.abilityOptions, ", ");
  let skills = join(entry.skillNames, ", ");
  let text = "Ability choices: " + abilities + ". Skills: " + skills + ". Origin feat: " + entry.originFeatId + ".";
  vdefinition(contentEntryLabel(entry.definition.name, entry.implemented), text);
}

function featEntryDefinition(entry) {
  vdefinition(contentEntryLabel(entry.definition.name, entry.implemented), entry.definition.description);
}

function equipmentPackDefinition(def) {
  vdefinition(def.name, def.description);
}

function viewCatalogContent(catalog) {
  vcard("2024 Core catalog", [
    vp([vtext("Species, classes, backgrounds, and origin feats are structured content records. Descriptions are original summaries; rules are represented as typed data and pure projections.")]),
    vdefinitionList("Species", [speciesEntryDefinition(e) for e <- catalog.speciesEntries]),
    vdefinitionList("Classes", [classEntryDefinition(e) for e <- catalog.classEntries]),
    vdefinitionList("Backgrounds", [backgroundEntryDefinition(e) for e <- catalog.backgroundEntries]),
    vdefinitionList("Origin feats", [featEntryDefinition(e) for e <- catalog.featEntries]),
    vdefinitionList("Equipment", [equipmentPackDefinition(d) for d <- contentDefinitionsByKind(catalog, WeaponContent) + contentDefinitionsByKind(catalog, ArmorContent) + contentDefinitionsByKind(catalog, ToolContent) + contentDefinitionsByKind(catalog, GearContent) + contentDefinitionsByKind(catalog, MagicItemContent)])
  ]);
}

function viewContentPacks(model) {
  panel("Content packs", [
    vfieldBlock("Loaded packs", [
      row("Active", activeContentPackLine(model.contentPacks)),
      row("Total", __str__(length(model.contentPacks)))
    ]),
    vdivClass(["catalog-list"], [contentPackRow(p) for p <- model.contentPacks]),
    viewCatalogContent(model.catalog)
  ]);
}

function viewSaveLoad(model) {
  panel("Save / Load", [
    vp([vtext("Import and export character files. Saved files contain build + play state only; derived sheet values are recomputed when loaded.")]),
    vdivClass(["button-row"], [
      vfile("character-import", "Import character...", [".pfchar", ".json"], fn v => ImportCharacterFile { value = v }),
      vdownload("Export selected...", exportFilename(model), exportDocumentText(model), "application/json", ExportDownloaded)
    ])
  ]);
}

function viewBuilderSelection(model) {
  let selection = model.selection;
  panel("Editor state", [
    field("Active tab", vselect("active-tab", tabChoices(), selection.activeTab, fn v => SetActiveTab { value = v })),
    field("Builder step", vselect("builder-step", builderStepChoices(), builderStepValue(selection.builderStep), fn v => SetBuilderStep { value = v })),
    field("Equipment kind", vselect("equipment-category", equipmentCategoryChoices(), selection.equipmentCategory, fn v => SetEquipmentCategory { value = v })),
    field("Search", vinput("equipment-search", selection.equipmentSearch, "equipment search", fn v => SetEquipmentSearch { value = v })),
    row("Expanded", listText(selection.expandedSections))
  ]);
}


function genderChoices() {
  [
    choice("any", "Any / unspecified"),
    choice("male", "Male"),
    choice("nonbinary", "Non-binary"),
    choice("female", "Female")
  ];
}

function genderOptions() {
  [
    voption("any", "Any", "✦"),
    voption("female", "Female", "♀"),
    voption("nonbinary", "Non-binary", "⚧"),
    voption("male", "Male", "♂")
  ];
}

function genderSelector(build) {
  voptionButtonGroup("gender", genderOptions(), genderId(build.identity.gender), fn v => SetGender { value = v });
}

function nameSuggestionStatus(build) {
  if hasNamesForSpecies(build.species) then
    "Names available for " + speciesName(build.species)
  else
    "No name suggestions for " + speciesName(build.species);
}


function hasSpeciesOptions(species) {
  let name = speciesName(species);
  name == "Dragonborn" || name == "Elf" || name == "Gnome" || name == "Goliath" || name == "Human" || name == "Tiefling";
}

function nextAfterIdentity(build) {
  if hasSpeciesOptions(build.species) then
    "species-options"
  else
    "class-options";
}

function backBeforeClassOptions(build) {
  if hasSpeciesOptions(build.species) then
    "species-options"
  else
    "identity";
}

function backBeforeAbilities(build) {
  "class-options";
}

