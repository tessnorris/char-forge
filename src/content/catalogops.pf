export function catalogStatus(catalog) {
  let speciesCount = length(catalog.speciesEntries);
  let classCount = length(catalog.classEntries);
  let backgroundCount = length(catalog.backgroundEntries);
  "Catalog loaded: " + __str__(speciesCount) + " species, " + __str__(classCount) + " classes, " + __str__(backgroundCount) + " backgrounds";
}


export function weaponId(weapon) {
  if weapon == Club then
    "weapon.club"
  else if weapon == Dagger then
    "weapon.dagger"
  else if weapon == Quarterstaff then
    "weapon.quarterstaff"
  else if weapon == Shortsword then
    "weapon.shortsword"
  else if weapon == Longsword then
    "weapon.longsword"
  else if weapon == Shortbow then
    "weapon.shortbow"
  else if weapon == Longbow then
    "weapon.longbow"
  else
    "weapon.shortsword";
}

export function armorId(armor) {
  if armor == NoArmor then
    "armor.none"
  else if armor == PaddedArmor then
    "armor.padded"
  else if armor == LeatherArmor then
    "armor.leather"
  else if armor == StuddedLeatherArmor then
    "armor.studded-leather"
  else if armor == ChainShirt then
    "armor.chain-shirt"
  else if armor == ScaleMail then
    "armor.scale-mail"
  else if armor == ChainMail then
    "armor.chain-mail"
  else
    "armor.leather";
}

export function toolId(tool) {
  if tool == ThievesTools then
    "tool.thieves-tools"
  else if tool == HerbalismKit then
    "tool.herbalism-kit"
  else if tool == DisguiseKit then
    "tool.disguise-kit"
  else if tool == PlayingCards then
    "tool.playing-cards"
  else
    "tool.thieves-tools";
}

export function gearId(gear) {
  if gear == ExplorerPack then
    "gear.explorer-pack"
  else if gear == ScholarPack then
    "gear.scholar-pack"
  else if gear == HolySymbol then
    "gear.holy-symbol"
  else if gear == Spellbook then
    "gear.spellbook"
  else if gear == Rope then
    "gear.rope"
  else if gear == Torch then
    "gear.torch"
  else
    "gear.explorer-pack";
}
