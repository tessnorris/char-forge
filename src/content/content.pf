export function speciesEntry(id, name, implemented, traitIds, description) {
  let def = core2024Metadata(id, name, SpeciesContent, ["species", "2024-phb"], description);
  speciesContentEntry(def, implemented, traitIds);
}

export function classEntry(id, name, implemented, hitDie, primaryAbilities, savingThrowNames, featureIds, description) {
  let def = core2024Metadata(id, name, ClassContent, ["class", "2024-phb"], description);
  classContentEntry(def, implemented, hitDie, primaryAbilities, savingThrowNames, featureIds);
}

export function backgroundEntry(id, name, implemented, abilityOptions, skillNames, toolIds, originFeatId, equipmentIds) {
  let abilityText = join(abilityOptions, ", ");
  let skillText = join(skillNames, ", ");
  let text = "Ability options: " + abilityText + ". Origin feat: " + originFeatId + ". Skills: " + skillText + ".";
  let def = core2024Metadata(id, name, BackgroundContent, ["background", "2024-phb"], text);
  backgroundContentEntry(def, implemented, abilityOptions, skillNames, toolIds, originFeatId, equipmentIds);
}

export function originFeatEntry(id, name, implemented, grants) {
  let def = core2024Metadata(id, name, FeatContent, ["feat", "origin", "2024-phb"], "2024 origin feat.");
  featContentEntry(def, implemented, "origin", "", grants);
}

