export function builtinCatalog() {
  let supported = ContentCatalog(
    definitions = [],
    speciesEntries = core2024SpeciesEntries(),
    classEntries = core2024ClassEntries(),
    backgroundEntries = core2024BackgroundEntries(),
    featEntries = core2024FeatEntries(),
    traitEntries = [],
    weaponEntries = supportedWeaponEntries(),
    armorEntries = supportedArmorEntries(),
    toolEntries = supportedToolEntries(),
    gearEntries = supportedGearEntries(),
    magicItemEntries = [],
    spellEntries = [],
    conditionEntries = [],
    species = [aasimarDefinition(), dragonbornDefinition(), dwarfDefinition(), elfDefinition(), gnomeDefinition(), goliathDefinition(), halflingDefinition(), humanDefinition(), orcDefinition(), tieflingDefinition()],
    classes = [barbarianDefinition(), bardDefinition(), clericDefinition(), druidDefinition(), fighterDefinition(), monkDefinition(), paladinDefinition(), rangerDefinition(), rogueDefinition(), sorcererDefinition(), warlockDefinition(), wizardDefinition()],
    backgrounds = [acolyteDefinition(), artisanDefinition(), charlatanDefinition(), criminalDefinition(), entertainerDefinition(), farmerDefinition(), guardDefinition(), guideDefinition(), hermitDefinition(), merchantDefinition(), nobleDefinition(), sageDefinition(), sailorDefinition(), scribeDefinition(), soldierDefinition(), wayfarerDefinition()],
    weapons = [clubDefinition(), daggerDefinition(), quarterstaffDefinition(), shortswordDefinition(), longswordDefinition(), shortbowDefinition(), longbowDefinition()],
    armor = [paddedArmorDefinition(), leatherArmorDefinition(), studdedLeatherArmorDefinition(), chainShirtDefinition(), scaleMailDefinition(), chainMailDefinition()],
    tools = [thievesToolsDefinition(), herbalismKitDefinition(), disguiseKitDefinition(), playingCardsDefinition()],
    gear = [explorerPackDefinition(), scholarPackDefinition(), holySymbolDefinition(), spellbookDefinition(), ropeDefinition(), torchDefinition()],
    magicItems = [],
    feats = [alertFeatDefinition()]
  );
  catalogWithTypedDefinitions(supported);
}

