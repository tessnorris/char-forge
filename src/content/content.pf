// Character Forge content catalog
//
// The catalog now has one canonical ContentDefinition shape with an exhaustive
// ContentKind union. Older kind-specific records still carry engine/rule payloads
// for this pass, but browsing/search/pack metadata operate over ContentDefinition.

import * from "../character/abilities";
import * from "../character/character";
import * from "../character/feats";
import * from "../character/traits";

export type ContentSource = {
  | BuiltInContent
  | HomebrewContent
}

export type ContentKind = {
  | SpeciesContent
  | ClassContent
  | BackgroundContent
  | WeaponContent
  | ArmorContent
  | ToolContent
  | GearContent
  | MagicItemContent
  | FeatContent
  | TraitContent
  | SpellContent
  | ConditionContent
}

export type ContentDefinition = { id, name, kind, source, tags, description }
export type ContentRef = { id, name, kind, source }

// Statically-shaped content-pack entries.
//
// Content packs are still data-driven, but they are not arbitrary metadata.
// Each entry has a ContentDefinition for shared catalog/search behavior plus
// kind-specific fields that the compiler can check. Runtime/homebrew JSON should
// decode into these same shapes and fail validation if required fields are
// missing.
export type SpeciesContentEntry = { definition, implemented, traitIds }
export type ClassContentEntry = { definition, implemented, hitDie, primaryAbilities, savingThrowNames, featureIds }
export type BackgroundContentEntry = { definition, implemented, abilityOptions, skillNames, toolIds, originFeatId, equipmentIds }
export type FeatContentEntry = { definition, implemented, featKind, prerequisite, grants }
export type TraitContentEntry = { definition, traitSource, grants }
export type WeaponContentEntry = { definition, implemented, damage, abilityName, properties }
export type ArmorContentEntry = { definition, implemented, baseAc, dexLimit, category }
export type ToolContentEntry = { definition, implemented, category }
export type GearContentEntry = { definition, implemented, category }
export type MagicItemContentEntry = { definition, implemented, rarity, grants }
export type SpellContentEntry = { definition, implemented, level, school }
export type ConditionContentEntry = { definition, implemented, grants }

export type SpeciesDefinition = { id, name, skills, tools, features, bonuses, source }
export type ClassDefinition = { id, name, hitDie, saves, skills, armor, weapons, features, bonuses, source }
export type BackgroundDefinition = { id, name, skills, tools, traits, feats, features, bonuses, source }
export type WeaponDefinition = { id, name, weapon, ability, damage, bonuses, source }
export type ArmorDefinition = { id, name, armor, baseAc, dexLimit, bonuses, source }
export type ToolDefinition = { id, name, tool, source }
export type GearDefinition = { id, name, gear, source }
export type MagicItemDefinition = { id, name, description, bonuses, source }

export type ContentCatalog = { definitions, speciesEntries, classEntries, backgroundEntries, featEntries, traitEntries, weaponEntries, armorEntries, toolEntries, gearEntries, magicItemEntries, spellEntries, conditionEntries, species, classes, backgrounds, weapons, armor, tools, gear, magicItems, feats }

export function sourceName(source) {
  match source with
  | BuiltInContent -> "built-in"
  | HomebrewContent -> "homebrew";
}

export function contentKindName(kind) {
  match kind with
  | SpeciesContent -> "species"
  | ClassContent -> "class"
  | BackgroundContent -> "background"
  | WeaponContent -> "weapon"
  | ArmorContent -> "armor"
  | ToolContent -> "tool"
  | GearContent -> "gear"
  | MagicItemContent -> "magic item"
  | FeatContent -> "feat"
  | TraitContent -> "trait"
  | SpellContent -> "spell"
  | ConditionContent -> "condition";
}

export function contentDefinition(id, name, kind, source, tags, description) {
  ContentDefinition(id = id, name = name, kind = kind, source = source, tags = tags, description = description);
}

export function core2024Metadata(id, name, kind, tags, description) {
  contentDefinition(id, name, kind, BuiltInContent, tags, description);
}

export function speciesContentEntry(def, implemented, traitIds) {
  SpeciesContentEntry(definition = def, implemented = implemented, traitIds = traitIds);
}

export function classContentEntry(def, implemented, hitDie, primaryAbilities, savingThrowNames, featureIds) {
  ClassContentEntry(definition = def, implemented = implemented, hitDie = hitDie, primaryAbilities = primaryAbilities, savingThrowNames = savingThrowNames, featureIds = featureIds);
}

export function backgroundContentEntry(def, implemented, abilityOptions, skillNames, toolIds, originFeatId, equipmentIds) {
  BackgroundContentEntry(definition = def, implemented = implemented, abilityOptions = abilityOptions, skillNames = skillNames, toolIds = toolIds, originFeatId = originFeatId, equipmentIds = equipmentIds);
}

export function featContentEntry(def, implemented, featKind, prerequisite, grants) {
  FeatContentEntry(definition = def, implemented = implemented, featKind = featKind, prerequisite = prerequisite, grants = grants);
}

export function traitContentEntry(def, traitSource, grants) {
  TraitContentEntry(definition = def, traitSource = traitSource, grants = grants);
}

export function weaponContentEntry(def, implemented, damage, abilityName, properties) {
  WeaponContentEntry(definition = def, implemented = implemented, damage = damage, abilityName = abilityName, properties = properties);
}

export function armorContentEntry(def, implemented, baseAc, dexLimit, category) {
  ArmorContentEntry(definition = def, implemented = implemented, baseAc = baseAc, dexLimit = dexLimit, category = category);
}

export function toolContentEntry(def, implemented, category) {
  ToolContentEntry(definition = def, implemented = implemented, category = category);
}

export function gearContentEntry(def, implemented, category) {
  GearContentEntry(definition = def, implemented = implemented, category = category);
}

export function magicItemContentEntry(def, implemented, rarity, grants) {
  MagicItemContentEntry(definition = def, implemented = implemented, rarity = rarity, grants = grants);
}

export function spellContentEntry(def, implemented, level, school) {
  SpellContentEntry(definition = def, implemented = implemented, level = level, school = school);
}

export function conditionContentEntry(def, implemented, grants) {
  ConditionContentEntry(definition = def, implemented = implemented, grants = grants);
}

export function definitionRef(def) {
  ContentRef(id = def.id, name = def.name, kind = def.kind, source = def.source);
}

export function contentDefinitionLine(def) {
  let source = sourceName(def.source);
  let kind = contentKindName(def.kind);
  def.name + " [" + kind + ":" + def.id + ", " + source + "]";
}

export function contentRefLine(ref) {
  let source = sourceName(ref.source);
  let kind = contentKindName(ref.kind);
  ref.name + " [" + kind + ":" + ref.id + ", " + source + "]";
}

export function speciesRef(def) {
  ContentRef(id = def.id, name = def.name, kind = SpeciesContent, source = def.source);
}

export function classRef(def) {
  ContentRef(id = def.id, name = def.name, kind = ClassContent, source = def.source);
}

export function backgroundRef(def) {
  ContentRef(id = def.id, name = def.name, kind = BackgroundContent, source = def.source);
}

export function weaponRef(def) {
  ContentRef(id = def.id, name = def.name, kind = WeaponContent, source = def.source);
}

export function armorRef(def) {
  ContentRef(id = def.id, name = def.name, kind = ArmorContent, source = def.source);
}

export function toolRef(def) {
  ContentRef(id = def.id, name = def.name, kind = ToolContent, source = def.source);
}

export function gearRef(def) {
  ContentRef(id = def.id, name = def.name, kind = GearContent, source = def.source);
}

export function magicItemRef(def) {
  ContentRef(id = def.id, name = def.name, kind = MagicItemContent, source = def.source);
}

export function featRef(def) {
  ContentRef(id = def.id, name = def.name, kind = FeatContent, source = BuiltInContent);
}

export function speciesContent(def) {
  contentDefinition(def.id, def.name, SpeciesContent, def.source, ["species"], "Playable species content.");
}

export function classContent(def) {
  contentDefinition(def.id, def.name, ClassContent, def.source, ["class"], "Playable class content.");
}

export function backgroundContent(def) {
  contentDefinition(def.id, def.name, BackgroundContent, def.source, ["background"], "Character background content.");
}

export function weaponContent(def) {
  contentDefinition(def.id, def.name, WeaponContent, def.source, ["equipment", "weapon"], def.damage + " damage");
}

export function armorContent(def) {
  contentDefinition(def.id, def.name, ArmorContent, def.source, ["equipment", "armor"], "Base AC " + __str__(def.baseAc));
}

export function toolContent(def) {
  contentDefinition(def.id, def.name, ToolContent, def.source, ["equipment", "tool"], "Tool proficiency or equipment.");
}

export function gearContent(def) {
  contentDefinition(def.id, def.name, GearContent, def.source, ["equipment", "gear"], "Adventuring gear.");
}

export function magicItemContent(def) {
  contentDefinition(def.id, def.name, MagicItemContent, def.source, ["equipment", "magic-item"], def.description);
}

export function featContent(def) {
  contentDefinition(def.id, def.name, FeatContent, BuiltInContent, ["feat", featKindName(def.kind)], def.summary);
}

export function traitContent(id, name, source, tags) {
  contentDefinition(id, name, TraitContent, source, tags, traitDescription(name));
}

export function definitionsFromTypedEntries(catalog) {
  let species = [e.definition for e <- catalog.speciesEntries];
  let classes = [e.definition for e <- catalog.classEntries];
  let backgrounds = [e.definition for e <- catalog.backgroundEntries];
  let feats = [e.definition for e <- catalog.featEntries];
  let traits = [e.definition for e <- catalog.traitEntries];
  let weapons = [e.definition for e <- catalog.weaponEntries];
  let armor = [e.definition for e <- catalog.armorEntries];
  let tools = [e.definition for e <- catalog.toolEntries];
  let gear = [e.definition for e <- catalog.gearEntries];
  let magicItems = [e.definition for e <- catalog.magicItemEntries];
  let spells = [e.definition for e <- catalog.spellEntries];
  let conditions = [e.definition for e <- catalog.conditionEntries];
  species + classes + backgrounds + feats + traits + weapons + armor + tools + gear + magicItems + spells + conditions;
}

export function catalogWithTypedDefinitions(catalog) {
  ContentCatalog(
    definitions = definitionsFromTypedEntries(catalog),
    speciesEntries = catalog.speciesEntries,
    classEntries = catalog.classEntries,
    backgroundEntries = catalog.backgroundEntries,
    featEntries = catalog.featEntries,
    traitEntries = catalog.traitEntries,
    weaponEntries = catalog.weaponEntries,
    armorEntries = catalog.armorEntries,
    toolEntries = catalog.toolEntries,
    gearEntries = catalog.gearEntries,
    magicItemEntries = catalog.magicItemEntries,
    spellEntries = catalog.spellEntries,
    conditionEntries = catalog.conditionEntries,
    species = catalog.species,
    classes = catalog.classes,
    backgrounds = catalog.backgrounds,
    weapons = catalog.weapons,
    armor = catalog.armor,
    tools = catalog.tools,
    gear = catalog.gear,
    magicItems = catalog.magicItems,
    feats = catalog.feats
  );
}

export function catalogWithDefinitions(catalog) {
  // Backward-compatible name: definitions are now derived from typed entries.
  catalogWithTypedDefinitions(catalog);
}

export function catalogWithExtraDefinitions(catalog, extraDefinitions) {
  // Legacy helper retained while call sites settle. The extraDefinitions list is
  // ignored intentionally; content-pack entries should be added through the
  // typed entry lists instead of arbitrary metadata definitions.
  catalogWithTypedDefinitions(catalog);
}

export function allContentDefinitions(catalog) {
  catalog.definitions;
}

export function contentDefinitionsByKind(catalog, kind) {
  filter(fn d => d.kind == kind, catalog.definitions);
}

export function allContentRefs(catalog) {
  [definitionRef(d) for d <- catalog.definitions];
}

export function matchingContentRefs(catalog, id) {
  let refs = allContentRefs(catalog);
  filter(fn r => r.id == id, refs);
}

export function contentNameOrMissing(catalog, id) {
  let matches = matchingContentRefs(catalog, id);
  if length(matches) > 0 then {
    let found = matches[0];
    found.name;
  } else {
    "missing content: " + id;
  }
}

export function requireContentName(catalog, id) {
  contentNameOrMissing(catalog, id);
}

