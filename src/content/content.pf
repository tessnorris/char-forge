    feats = []
  ));
}

export function mergeCatalogs(primary, extra) {
  ContentCatalog(
    definitions = primary.definitions + extra.definitions,
    speciesEntries = primary.speciesEntries + extra.speciesEntries,
    classEntries = primary.classEntries + extra.classEntries,
    backgroundEntries = primary.backgroundEntries + extra.backgroundEntries,
    featEntries = primary.featEntries + extra.featEntries,
    traitEntries = primary.traitEntries + extra.traitEntries,
    weaponEntries = primary.weaponEntries + extra.weaponEntries,
    armorEntries = primary.armorEntries + extra.armorEntries,
    toolEntries = primary.toolEntries + extra.toolEntries,
    gearEntries = primary.gearEntries + extra.gearEntries,
    magicItemEntries = primary.magicItemEntries + extra.magicItemEntries,
    spellEntries = primary.spellEntries + extra.spellEntries,
    conditionEntries = primary.conditionEntries + extra.conditionEntries,
    species = primary.species + extra.species,
    classes = primary.classes + extra.classes,
    backgrounds = primary.backgrounds + extra.backgrounds,
    weapons = primary.weapons + extra.weapons,
    armor = primary.armor + extra.armor,
    tools = primary.tools + extra.tools,
    gear = primary.gear + extra.gear,
    magicItems = primary.magicItems + extra.magicItems,
    feats = primary.feats + extra.feats
  );
}

export function demoCatalog() {
  mergeCatalogs(builtinCatalog(), sampleHomebrewCatalog());
}
