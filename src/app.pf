// Character Forge web app pass 2
//
// Run from ~/src/pf/character-forge with:
//   pfun --serve ./src/app.pf
//
// This pass keeps browser values at the edge. Select boxes carry stable
// catalog IDs, catalogops resolves them, and the domain stays strongly typed.

import * from "io";
import * from "$PFUN_HOME/lib/htmllib";
import * from "$PFUN_HOME/lib/viewlib";
import * from "$PFUN_HOME/lib/tea";
import * from "./character/abilities";
import * from "./character/character";
import * from "./character/rules";
import * from "./content/content";
import * from "./content/contentpack";
import * from "./content/catalogops";
import * from "./character/buildops";
import * from "./character/stateops";
import * from "./character/context";
import * from "./character/resources";
import * from "./character/actions";
import * from "./app/appmodel";
import * from "./app/documentops";
import * from "./app/saveload";
import * from "./builder/abilitybuilder";
import * from "./builder/namegenerator";

// ── TEA plumbing ──────────────────────────────────────────────────────────────

function noCmd(model) {
  UpdateResult { model, cmdNone() };
}

function defaultSelection() {
  BuilderSelection(
    activeTab = "builder",
    builderStep = IdentityStep,
    equipmentCategory = "weapons",
    equipmentSearch = "",
    expandedSections = ["identity", "abilities", "equipment"],
    abilityMethod = "manual",
    standardSelectedScore = "",
    standardStrength = "",
    standardDexterity = "",
    standardConstitution = "",
    standardIntelligence = "",
    standardWisdom = "",
    standardCharisma = "",
    backgroundBonusMode = "plus-two-plus-one",
    backgroundBonusPrimary = "dex",
    backgroundBonusSecondary = "con",
    backgroundBonusTertiary = "int",
    rollMode = "4d6-drop-lowest",
    rollSeed = "",
    rollSummary = "No rolls yet"
  );
}

function init() {
  let packs = defaultContentPacks();
  let catalog = catalogFromPacks(packs);
  let documents = initialDocuments();
  let selected = firstDocument(documents);
  let model = Model(
    catalog = catalog,
    contentPacks = packs,
    documents = documents,
    selectedId = selected.id,
    character = selected.character,
    turn = selected.turn,
    status = catalogStatus(catalog),
    damageText = "7",
    healingText = "6",
    tempText = "5",
    saveText = "",
    importText = "",
    selection = defaultSelection()
  );
  noCmd(model);
}

