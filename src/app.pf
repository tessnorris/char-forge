// ── TEA plumbing ──────────────────────────────────────────────────────────────

function noCmd(model) {
  UpdateResult { model, cmdNone() };
}

function defaultSelection() {
  BuilderSelection(
    activeTab = "builder",
    builderStep = "identity",
    equipmentCategory = "weapons",
    equipmentSearch = "",
    expandedSections = ["identity", "abilities", "equipment"],
    abilityMethod = "manual",
    standardSelectedScore = "",
    standardStrength = "",
    standardDexterity = "",
    standardConstitution = "",
    standardIntelligence = "",
    standardWisdom = "",
    standardCharisma = "",
    scoreSlotOne = "",
    scoreSlotTwo = "",
    scoreSlotThree = "",
    scoreSlotFour = "",
    scoreSlotFive = "",
    scoreSlotSix = "",
    backgroundBonusMode = "plus-two-plus-one",
    backgroundBonusPrimary = "dex",
    backgroundBonusSecondary = "con",
    backgroundBonusTertiary = "int",
    rollMode = "4d6-drop-lowest",
    rollSeed = "8675309",
    rollSummary = "No rolls yet"
  );
}

function init() {
  let packs = defaultContentPacks();
  let catalog = catalogFromPacks(packs);
  let documents = initialDocuments();
  let selected = firstDocument(documents);
  let model = Model(
    catalog = catalog,
    contentPacks = packs,
    documents = documents,
    selectedId = selected.id,
    character = selected.character,
    turn = selected.turn,
    status = catalogStatus(catalog),
    damageText = "7",
    healingText = "6",
    tempText = "5",
    saveText = "",
    importText = "",
    selection = defaultSelection()
  );
  noCmd(model);
}

