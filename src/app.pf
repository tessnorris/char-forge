function applyScoresToCharacter(character, scores) {
  let c1 = setAbilityScore(character, Strength, scores.strength);
  let c2 = setAbilityScore(c1, Dexterity, scores.dexterity);
  let c3 = setAbilityScore(c2, Constitution, scores.constitution);
  let c4 = setAbilityScore(c3, Intelligence, scores.intelligence);
  let c5 = setAbilityScore(c4, Wisdom, scores.wisdom);
  setAbilityScore(c5, Charisma, scores.charisma);
}

function addAbilityBonus(character, ability, amount) {
  let current = getScore(character.build.scores, ability);
  setAbilityScore(character, ability, current + amount);
}

function applySelectedBackgroundBonuses(character, selection) {
  let primary = abilityFromId(selection.backgroundBonusPrimary);
  let secondary = abilityFromId(selection.backgroundBonusSecondary);
  let tertiary = abilityFromId(selection.backgroundBonusTertiary);
  if selection.backgroundBonusMode == "plus-one-plus-one-plus-one" then {
    let c1 = addAbilityBonus(character, primary, 1);
    let c2 = addAbilityBonus(c1, secondary, 1);
    addAbilityBonus(c2, tertiary, 1);
  } else {
    let c1 = addAbilityBonus(character, primary, 2);
    addAbilityBonus(c1, secondary, 1);
  }
}

function removeSelectedBackgroundBonuses(character, selection) {
  let primary = abilityFromId(selection.backgroundBonusPrimary);
  let secondary = abilityFromId(selection.backgroundBonusSecondary);
  let tertiary = abilityFromId(selection.backgroundBonusTertiary);
  if selection.backgroundBonusMode == "plus-one-plus-one-plus-one" then {
    let c1 = addAbilityBonus(character, primary, -1);
    let c2 = addAbilityBonus(c1, secondary, -1);
    addAbilityBonus(c2, tertiary, -1);
  } else {
    let c1 = addAbilityBonus(character, primary, -2);
    addAbilityBonus(c1, secondary, -1);
  }
}

function transitionBackgroundBonuses(character, oldSelection, newSelection) {
  applySelectedBackgroundBonuses(removeSelectedBackgroundBonuses(character, oldSelection), newSelection);
}

function applyScoresWithBackgroundBonuses(character, scores, selection) {
  applySelectedBackgroundBonuses(applyScoresToCharacter(character, scores), selection);
}

function setScoreWithBackgroundBonuses(character, ability, score, selection) {
  let base = removeSelectedBackgroundBonuses(character, selection);
  let changed = setAbilityScore(base, ability, score);
  applySelectedBackgroundBonuses(changed, selection);
}

function adjustPointBuyScore(character, ability, delta, selection) {
  let base = removeSelectedBackgroundBonuses(character, selection);
  let current = getScore(base.build.scores, ability);
  let nextScore = clampPointBuy(current + delta);
  applySelectedBackgroundBonuses(setAbilityScore(base, ability, nextScore), selection);
}


function withContentPacks(model, packs, status) {
  let catalog = catalogFromPacks(packs);
  noCmd(Model(
    catalog = catalog,
    contentPacks = packs,
    documents = model.documents,
    selectedId = model.selectedId,
    character = model.character,
    turn = model.turn,
    status = status,
    damageText = model.damageText,
    healingText = model.healingText,
    tempText = model.tempText,
    saveText = model.saveText,
    importText = model.importText,
    selection = model.selection
  ));
}

function fieldText(payload) {
  payload.value;
}

function fieldInt(payload) {
  toInt(toFloat(payload.value));
}

function intFromText(text) {
  toInt(toFloat(text));
}


function builderStepFromText(value) {
  if value == "identity" then
    "identity"
  else if value == "species-options" then
    "species-options"
  else if value == "class-options" then
    "class-options"
  else if value == "abilities" then
    "abilities"
  else if value == "equipment" then
    "equipment"
  else
    "review";
}


type ScoreRoll = { rng, value }
type AbilityRollResult = { rng, scores, summary }

function minInt(a, b) {
  a < b ? a : b;
}

function minFour(a, b, c, d) {
  minInt(minInt(a, b), minInt(c, d));
}

function safeSeed(text) {
  text == "" ? 8675309 : toInt(toFloat(text));
}

function rollD6From(rng) {
  rollDieOfSize(rng, 6);
}

function rollD6Reroll1From(rng) {
  let r = rollD6From(rng);
  if r.value <= 1 then
    rollD6Reroll1From(r.rng)
  else
    r;
}

function rollD6Reroll12From(rng) {
  let r = rollD6From(rng);
  if r.value <= 2 then
    rollD6Reroll12From(r.rng)
  else
    r;
}

function roll3d6ScoreFrom(rng) {
  let a = rollD6From(rng);
  let b = rollD6From(a.rng);
  let c = rollD6From(b.rng);
  ScoreRoll(rng = c.rng, value = a.value + b.value + c.value);
}

function roll4d6DropLowestScoreFrom(rng) {
  let a = rollD6From(rng);
  let b = rollD6From(a.rng);
  let c = rollD6From(b.rng);
  let d = rollD6From(c.rng);
  ScoreRoll(rng = d.rng, value = a.value + b.value + c.value + d.value - minFour(a.value, b.value, c.value, d.value));
}

function roll4d6Reroll1ScoreFrom(rng) {
  let a = rollD6Reroll1From(rng);
  let b = rollD6Reroll1From(a.rng);
  let c = rollD6Reroll1From(b.rng);
  let d = rollD6Reroll1From(c.rng);
  ScoreRoll(rng = d.rng, value = a.value + b.value + c.value + d.value - minFour(a.value, b.value, c.value, d.value));
}

function roll4d6Reroll12ScoreFrom(rng) {
  let a = rollD6Reroll12From(rng);
  let b = rollD6Reroll12From(a.rng);
  let c = rollD6Reroll12From(b.rng);
  let d = rollD6Reroll12From(c.rng);
  ScoreRoll(rng = d.rng, value = a.value + b.value + c.value + d.value - minFour(a.value, b.value, c.value, d.value));
}

function roll2d6Plus6ScoreFrom(rng) {
  let a = rollD6From(rng);
  let b = rollD6From(a.rng);
  ScoreRoll(rng = b.rng, value = a.value + b.value + 6);
}

function rollScoreByModeFrom(rng, mode) {
  if mode == "3d6" then
    roll3d6ScoreFrom(rng)
  else if mode == "2d6-plus-6" then
    roll2d6Plus6ScoreFrom(rng)
  else if mode == "4d6-reroll-ones" then
    roll4d6Reroll1ScoreFrom(rng)
  else if mode == "4d6-reroll-one-two" then
    roll4d6Reroll12ScoreFrom(rng)
  else
    roll4d6DropLowestScoreFrom(rng);
}

function rollModeSummary(mode) {
  if mode == "3d6" then
    "3d6 in order"
  else if mode == "2d6-plus-6" then
    "2d6 + 6"
  else if mode == "4d6-reroll-ones" then
    "4d6 drop lowest, rerolling 1s"
  else if mode == "4d6-reroll-one-two" then
    "4d6 drop lowest, rerolling 1s and 2s"
  else
    "4d6 drop lowest";
}

function rollAbilityScoresFromSeed(mode, seedText) {
  let start = Rng { seed = safeSeed(seedText) };
  let str = rollScoreByModeFrom(start, mode);
  let dex = rollScoreByModeFrom(str.rng, mode);
  let con = rollScoreByModeFrom(dex.rng, mode);
  let intv = rollScoreByModeFrom(con.rng, mode);
  let wis = rollScoreByModeFrom(intv.rng, mode);
  let cha = rollScoreByModeFrom(wis.rng, mode);
  let scores = AbilityScores(
    strength = str.value,
    dexterity = dex.value,
    constitution = con.value,
    intelligence = intv.value,
    wisdom = wis.value,
    charisma = cha.value
  );
  AbilityRollResult(
    rng = cha.rng,
    scores = scores,
    summary = rollModeSummary(mode) + ": " + __str__(str.value) + ", " + __str__(dex.value) + ", " + __str__(con.value) + ", " + __str__(intv.value) + ", " + __str__(wis.value) + ", " + __str__(cha.value)
  );
}

function assignAbilityResult(model, character, ability, label) {
  let selection = assignSelectedScoreSlot(model.selection, ability);
  let nextCharacter = applyAssignmentSelection(character, selection);
  withModel(model, nextCharacter, model.turn, label + " assigned", model.damageText, model.healingText, model.tempText, model.saveText, model.importText, selection);
}

proc update(msg, model) {
  let character = model.character;
  let build = character.build;
  match msg with
  | NoOp -> noCmd(model)
  | NewCharacter -> {
      let currentDocs = syncedDocuments(model, model.character, model.turn);
      let doc = newCharacterDocument(currentDocs);
      let documents = addDocument(currentDocs, doc);
      buildModel(model, documents, doc.id, doc.character, doc.turn, "New character created", model.damageText, model.healingText, model.tempText, model.saveText, model.importText, model.selection);
    }
  | SelectCharacter p -> {
      let currentDocs = syncedDocuments(model, model.character, model.turn);
      let doc = findDocument(currentDocs, fieldText(p));
      buildModel(model, currentDocs, doc.id, doc.character, doc.turn, "Selected " + doc.character.build.identity.name, model.damageText, model.healingText, model.tempText, model.saveText, model.importText, model.selection);
    }
  | DuplicateSelected -> {
      let currentDocs = syncedDocuments(model, model.character, model.turn);
      let doc = duplicateSelectedDocument(currentDocs, model.selectedId);
      let documents = addDocument(currentDocs, doc);
      buildModel(model, documents, doc.id, doc.character, doc.turn, "Duplicated character", model.damageText, model.healingText, model.tempText, model.saveText, model.importText, model.selection);
    }
  | DeleteSelected -> {
      let currentDocs = syncedDocuments(model, model.character, model.turn);
      let remaining = ensureNonEmpty(deleteDocument(currentDocs, model.selectedId));
      let doc = firstDocument(remaining);
      buildModel(model, remaining, doc.id, doc.character, doc.turn, "Deleted character", model.damageText, model.healingText, model.tempText, model.saveText, model.importText, model.selection);
    }
  | SetName p -> withCharacter(model, setName(character, fieldText(p)), "Name updated")
  | SetGender p -> withCharacter(model, setGender(character, genderFromId(fieldText(p))), "Gender updated")
  | SuggestName -> {
      let suggestion = suggestCharacterName(Rng { seed = safeSeed(model.selection.rollSeed) }, build.species, build.identity.gender);
      let named = suggestion.name == "" ? character : setName(character, suggestion.name);
      let withSeed = setSelectionRollSeed(model.selection, __str__(suggestion.rng.seed));
      let nextSelection = setSelectionRollSummary(withSeed, suggestion.status);
      withModel(model, named, model.turn, suggestion.status, model.damageText, model.healingText, model.tempText, model.saveText, model.importText, nextSelection);
    }
  | SelectSpecies p -> {
      let species = speciesFromId(fieldText(p), build.species);
      withCharacter(model, setSpecies(character, species), "Species updated");
    }
  | SetDragonbornAncestry p -> {
      let next = setDragonbornAncestry(character, dragonbornAncestryFromId(fieldText(p)));
      withCharacter(model, next, "Dragonborn ancestry selected: " + dragonbornAncestryName(next.build.speciesOptions.dragonbornAncestry));
    }
  | SetElfLineage p -> {
      let next = setElfLineage(character, elfLineageFromId(fieldText(p)));
      withCharacter(model, next, "Elf lineage selected: " + elfLineageName(next.build.speciesOptions.elfLineage));
    }
  | SetElfBonusSkill p -> {
      let next = setElfBonusSkill(character, skillFromId(fieldText(p), Perception));
      withCharacter(model, next, "Elf bonus skill selected: " + skillName(next.build.speciesOptions.elfBonusSkill));
    }
  | SetGnomeLineage p -> {
      let next = setGnomeLineage(character, gnomeLineageFromId(fieldText(p)));
      withCharacter(model, next, "Gnome lineage selected: " + gnomeLineageName(next.build.speciesOptions.gnomeLineage));
    }
  | SetGoliathAncestry p -> {
      let next = setGoliathAncestry(character, goliathAncestryFromId(fieldText(p)));
      withCharacter(model, next, "Goliath ancestry selected: " + goliathAncestryName(next.build.speciesOptions.goliathAncestry));
    }
  | SetHumanBonusSkill p -> {
      let next = setHumanBonusSkill(character, skillFromId(fieldText(p), Perception));
      withCharacter(model, next, "Human bonus skill selected: " + skillName(next.build.speciesOptions.humanBonusSkill));
    }
  | SetHumanBonusFeat p -> {
      let next = setHumanBonusFeat(character, fieldText(p));
      withCharacter(model, next, "Human bonus feat selected");
    }
  | SetTieflingLineage p -> {
      let next = setTieflingLineage(character, tieflingLineageFromId(fieldText(p)));
      withCharacter(model, next, "Tiefling legacy selected: " + tieflingLineageName(next.build.speciesOptions.tieflingLineage));
    }
  | SetLineageSpellcastingAbility p -> {
      let next = setLineageSpellcastingAbility(character, fieldText(p));
      withCharacter(model, next, "Lineage spellcasting ability selected: " + abilitySpellcastingName(next.build.speciesOptions.lineageSpellcastingAbility));
    }
  | SelectClass p -> {
      let class = classFromId(fieldText(p), build.class);
      withCharacter(model, setClass(character, class), "Class updated");
    }
  | SetClassSkill p -> {
      let skill = skillFromId(fieldText(p), Perception);
      let next = toggleClassSkill(character, skill);
      withCharacter(model, next, "Class skill selection updated");
    }
  | SetFightingStyle p -> {
      let style = fightingStyleFromId(fieldText(p));
      withCharacter(model, setFightingStyle(character, style), "Fighting style selected: " + fightingStyleName(style));
    }
  | SetClericOrder p -> {
      let order = clericOrderFromId(fieldText(p));
      withCharacter(model, setClericOrder(character, order), "Divine Order selected: " + clericOrderName(order));
    }
  | SetDruidOrder p -> {
      let order = druidOrderFromId(fieldText(p));
      withCharacter(model, setDruidOrder(character, order), "Primal Order selected: " + druidOrderName(order));
    }
  | SetExpertiseSkillOne p -> {
      let skill = skillFromId(fieldText(p), Stealth);
      withCharacter(model, setExpertiseSkillOne(character, skill), "Expertise skill selected: " + skillName(skill));
    }
  | SetExpertiseSkillTwo p -> {
      let skill = skillFromId(fieldText(p), SleightOfHand);
      withCharacter(model, setExpertiseSkillTwo(character, skill), "Expertise skill selected: " + skillName(skill));
    }
  | SelectBackground p -> {
      let background = backgroundFromId(fieldText(p), build.background);
      withCharacter(model, setBackground(character, background), "Background updated");
    }
  | SetLevel p -> withCharacter(model, setLevel(character, fieldInt(p)), "Level updated")
  | SetStrength p -> withCharacter(model, setScoreWithBackgroundBonuses(character, Strength, fieldInt(p), model.selection), "Strength updated")
  | SetDexterity p -> withCharacter(model, setScoreWithBackgroundBonuses(character, Dexterity, fieldInt(p), model.selection), "Dexterity updated")
  | SetConstitution p -> withCharacter(model, setScoreWithBackgroundBonuses(character, Constitution, fieldInt(p), model.selection), "Constitution updated")
  | SetIntelligence p -> withCharacter(model, setScoreWithBackgroundBonuses(character, Intelligence, fieldInt(p), model.selection), "Intelligence updated")
  | SetWisdom p -> withCharacter(model, setScoreWithBackgroundBonuses(character, Wisdom, fieldInt(p), model.selection), "Wisdom updated")
  | SetCharisma p -> withCharacter(model, setScoreWithBackgroundBonuses(character, Charisma, fieldInt(p), model.selection), "Charisma updated")
  | IncreaseStrength -> withCharacter(model, adjustPointBuyScore(character, Strength, 1, model.selection), "Strength increased")
  | DecreaseStrength -> withCharacter(model, adjustPointBuyScore(character, Strength, -1, model.selection), "Strength decreased")
  | IncreaseDexterity -> withCharacter(model, adjustPointBuyScore(character, Dexterity, 1, model.selection), "Dexterity increased")
  | DecreaseDexterity -> withCharacter(model, adjustPointBuyScore(character, Dexterity, -1, model.selection), "Dexterity decreased")
  | IncreaseConstitution -> withCharacter(model, adjustPointBuyScore(character, Constitution, 1, model.selection), "Constitution increased")
  | DecreaseConstitution -> withCharacter(model, adjustPointBuyScore(character, Constitution, -1, model.selection), "Constitution decreased")
  | IncreaseIntelligence -> withCharacter(model, adjustPointBuyScore(character, Intelligence, 1, model.selection), "Intelligence increased")
  | DecreaseIntelligence -> withCharacter(model, adjustPointBuyScore(character, Intelligence, -1, model.selection), "Intelligence decreased")
  | IncreaseWisdom -> withCharacter(model, adjustPointBuyScore(character, Wisdom, 1, model.selection), "Wisdom increased")
  | DecreaseWisdom -> withCharacter(model, adjustPointBuyScore(character, Wisdom, -1, model.selection), "Wisdom decreased")
  | IncreaseCharisma -> withCharacter(model, adjustPointBuyScore(character, Charisma, 1, model.selection), "Charisma increased")
  | DecreaseCharisma -> withCharacter(model, adjustPointBuyScore(character, Charisma, -1, model.selection), "Charisma decreased")
  | ToggleShield p -> withCharacter(model, setShield(character, p.value), "Shield toggled")
  | SetDamageText p -> withInputs(model, fieldText(p), model.healingText, model.tempText, "Damage amount edited")
  | SetHealingText p -> withInputs(model, model.damageText, fieldText(p), model.tempText, "Healing amount edited")
  | SetTempText p -> withInputs(model, model.damageText, model.healingText, fieldText(p), "Temp HP amount edited")
  | SetSaveText p -> withSaveText(model, fieldText(p), "Export text edited")
  | SetImportText p -> withImportText(model, fieldText(p), "Import text edited")
  | ExportSelected -> {
      let text = saveDocument(selectedDocument(model));
      withSaveText(model, text, "Exported selected character")
    }
  | ExportDownloaded -> noCmd(Model(
      catalog = model.catalog,
      contentPacks = model.contentPacks,
      documents = model.documents,
      selectedId = model.selectedId,
      character = model.character,
      turn = model.turn,
      status = "Export downloaded",
      damageText = model.damageText,
      healingText = model.healingText,
      tempText = model.tempText,
      saveText = model.saveText,
      importText = model.importText,
      selection = model.selection
    ))
  | ImportCharacterFile p -> {
      let currentDocs = syncedDocuments(model, model.character, model.turn);
      let fallback = selectedDocument(model);
      let importText = fieldText(p);
      let result = loadDocument(model.catalog, importText, fallback);
      let withoutOld = deleteDocument(currentDocs, result.document.id);
      let documents = addDocument(withoutOld, result.document);
      buildModel(model, documents, result.document.id, result.document.character, result.document.turn, result.status, model.damageText, model.healingText, model.tempText, saveDocument(result.document), "", model.selection);
    }
  | ImportDocument -> {
      let currentDocs = syncedDocuments(model, model.character, model.turn);
      let fallback = selectedDocument(model);
      let result = loadDocument(model.catalog, model.importText, fallback);
      let withoutOld = deleteDocument(currentDocs, result.document.id);
      let documents = addDocument(withoutOld, result.document);
      buildModel(model, documents, result.document.id, result.document.character, result.document.turn, result.status, model.damageText, model.healingText, model.tempText, saveDocument(result.document), model.importText, model.selection);
    }
  | SetNotesText p -> {
      let result = setNotes(character, fieldText(p));
      withCharacter(model, result.character, result.line);
    }
  | SetActiveTab p -> {
      let selection = setSelectionTab(model.selection, fieldText(p));
      withSelection(model, selection, "Editor tab changed");
    }
  | SetBuilderStep p -> {
      let selection = setSelectionBuilderStep(model.selection, builderStepFromText(fieldText(p)));
      withSelection(model, selection, "Builder step changed");
    }
  | GoIdentity -> {
      let selection = setSelectionBuilderStep(model.selection, "identity");
      withSelection(model, selection, "Builder step changed");
    }
  | GoSpeciesOptions -> {
      let selection = setSelectionBuilderStep(model.selection, "species-options");
      withSelection(model, selection, "Builder step changed");
    }
  | GoClassOptions -> {
      let selection = setSelectionBuilderStep(model.selection, "class-options");
      withSelection(model, selection, "Builder step changed");
    }
  | GoAbilities -> {
      let selection = setSelectionBuilderStep(model.selection, "abilities");
      withSelection(model, selection, "Builder step changed");
    }
  | GoEquipment -> {
      let selection = setSelectionBuilderStep(model.selection, "equipment");
      withSelection(model, selection, "Builder step changed");
    }
  | GoReview -> {
      let selection = setSelectionBuilderStep(model.selection, "review");
      withSelection(model, selection, "Builder step changed");
    }
  | SetEquipmentCategory p -> {
      let selection = setSelectionEquipmentCategory(model.selection, fieldText(p));
      withSelection(model, selection, "Equipment category changed");
    }
  | SetEquipmentSearch p -> {
      let selection = setSelectionEquipmentSearch(model.selection, fieldText(p));
      withSelection(model, selection, "Equipment search edited");
    }
  | SetAbilityMethod p -> {
      let rawSelection = setSelectionAbilityMethod(model.selection, fieldText(p));
      let selection = fieldText(p) == "standard-array" ? standardArraySelection(rawSelection) : rawSelection;
      withSelection(model, selection, "Ability method changed");
    }

  | SelectStandardScore p -> {
      let selection = setSelectionStandardSelectedScore(model.selection, fieldText(p));
      withSelection(model, selection, "Standard array score selected");
    }
  | AssignStandardStrength -> assignAbilityResult(model, character, Strength, "Strength")
  | AssignStandardDexterity -> assignAbilityResult(model, character, Dexterity, "Dexterity")
  | AssignStandardConstitution -> assignAbilityResult(model, character, Constitution, "Constitution")
  | AssignStandardIntelligence -> assignAbilityResult(model, character, Intelligence, "Intelligence")
  | AssignStandardWisdom -> assignAbilityResult(model, character, Wisdom, "Wisdom")
  | AssignStandardCharisma -> assignAbilityResult(model, character, Charisma, "Charisma")
  | SetBackgroundBonusMode p -> {
      let selection = setSelectionBackgroundBonusMode(model.selection, fieldText(p));
      let next = transitionBackgroundBonuses(character, model.selection, selection);
      withModel(model, next, model.turn, "Background bonus mode changed", model.damageText, model.healingText, model.tempText, model.saveText, model.importText, selection);
    }
  | SetBackgroundBonusPrimary p -> {
      let selection = setSelectionBackgroundBonusPrimary(model.selection, fieldText(p));
      let next = transitionBackgroundBonuses(character, model.selection, selection);
      withModel(model, next, model.turn, "Background primary bonus changed", model.damageText, model.healingText, model.tempText, model.saveText, model.importText, selection);
    }
  | SetBackgroundBonusSecondary p -> {
      let selection = setSelectionBackgroundBonusSecondary(model.selection, fieldText(p));
      let next = transitionBackgroundBonuses(character, model.selection, selection);
      withModel(model, next, model.turn, "Background secondary bonus changed", model.damageText, model.healingText, model.tempText, model.saveText, model.importText, selection);
    }
  | SetBackgroundBonusTertiary p -> {
      let selection = setSelectionBackgroundBonusTertiary(model.selection, fieldText(p));
      let next = transitionBackgroundBonuses(character, model.selection, selection);
      withModel(model, next, model.turn, "Background tertiary bonus changed", model.damageText, model.healingText, model.tempText, model.saveText, model.importText, selection);
    }
  | ApplyBackgroundBonuses -> {
      let next = applySelectedBackgroundBonuses(character, model.selection);
      withCharacter(model, next, "Background ability bonuses applied");
    }
  | ApplyStandardArray -> {
      let next = applyScoresWithBackgroundBonuses(character, standardArrayScores(), model.selection);
      let selection = standardArrayDefaultSelection(model.selection);
      withModel(model, next, model.turn, "Standard array applied", model.damageText, model.healingText, model.tempText, model.saveText, model.importText, selection);
    }
  | ResetPointBuy -> {
      let next = applyScoresWithBackgroundBonuses(character, pointBuyBaseScores(), model.selection);
      let selection = clearStandardArraySelection(model.selection);
      withModel(model, next, model.turn, "Point buy reset to 8s", model.damageText, model.healingText, model.tempText, model.saveText, model.importText, selection);
    }
  | SetRollMode p -> {
      let selection = setSelectionRollMode(model.selection, fieldText(p));
      withSelection(model, selection, "Roll mode changed");
    }
  | SetRollSeed p -> {
      let selection = setSelectionRollSeed(model.selection, fieldText(p));
      withSelection(model, selection, "Roll seed changed");
    }
  | RollAbilityScores -> {
      let rolled = rollAbilityScoresFromSeed(model.selection.rollMode, model.selection.rollSeed);
      let summary = rolled.summary;
      let withSeed = setSelectionRollSeed(model.selection, __str__(rolled.rng.seed));
      if model.selection.rollMode == "3d6" then {
        let nextCharacter = applyScoresWithBackgroundBonuses(character, rolled.scores, withSeed);
        let nextSelection = clearStandardArraySelection(setSelectionRollSummary(withSeed, summary));
        withModel(model, nextCharacter, model.turn, "Rolled ability scores in order", model.damageText, model.healingText, model.tempText, model.saveText, model.importText, nextSelection);
      } else {
        let nextSelection = rolledScoreSelection(setSelectionRollSummary(withSeed, summary), rolled.scores, summary);
        let nextCharacter = applyAssignmentSelection(character, nextSelection);
        withModel(model, nextCharacter, model.turn, "Rolled score pool ready to assign", model.damageText, model.healingText, model.tempText, model.saveText, model.importText, nextSelection);
      }
    }
  | AddWeaponById p -> {
      let weapon = weaponFromId(model.catalog, fieldText(p), Shortsword);
      withCharacter(model, equipWeapon(character, weapon), "Weapon equipped");
    }
  | AddArmorById p -> {
      let armor = armorFromId(model.catalog, fieldText(p), LeatherArmor);
      withCharacter(model, equipArmor(character, armor), "Armor equipped");
    }
  | AddToolById p -> {
      let tool = toolFromId(model.catalog, fieldText(p), ThievesTools);
      withCharacter(model, addTool(character, tool), "Tool added");
    }
  | AddGearById p -> {
      let gear = gearFromId(model.catalog, fieldText(p), ExplorerPack);
      withCharacter(model, addGear(character, gear), "Gear added");
    }
  | RemoveWeaponById p -> {
      let weapon = weaponFromId(model.catalog, fieldText(p), Shortsword);
      withCharacter(model, unequipWeapon(character, weapon), "Weapon removed");
    }
  | ClearArmorMsg -> withCharacter(model, clearArmor(character), "Armor cleared")
  | RemoveToolById p -> {
      let tool = toolFromId(model.catalog, fieldText(p), ThievesTools);
      withCharacter(model, removeTool(character, tool), "Tool removed");
    }
  | RemoveGearById p -> {
      let gear = gearFromId(model.catalog, fieldText(p), ExplorerPack);
      withCharacter(model, removeGear(character, gear), "Gear removed");
    }
  | ApplyDamage -> {
      let amount = intFromText(model.damageText);
      let result = takeDamage(character, amount);
      withCharacter(model, result.character, result.line);
    }
  | ApplyHealing -> {
      let amount = intFromText(model.healingText);
      let result = heal(character, amount);
      withCharacter(model, result.character, result.line);
    }
  | ApplyTempHp -> {
      let amount = intFromText(model.tempText);
      let result = gainTemporaryHp(character, amount);
      withCharacter(model, result.character, result.line);
    }
  | UseSneakAttack -> {
      let nextTurn = useSneakAttack(model.turn);
      withTurn(model, nextTurn, "Sneak Attack spent for this turn");
    }
  | StartTurn -> {
      let nextTurn = startTurn(model.turn);
      withTurn(model, nextTurn, "New turn started; turn resources reset");
    }
  | ShortRestMsg -> {
      let result = shortRest(character);
      withCharacter(model, result.character, result.line);
    }
  | LongRestMsg -> {
      let result = longRest(character);
      withModel(model, result.character, sampleTurnResources(), result.line, model.damageText, model.healingText, model.tempText, model.saveText, model.importText, model.selection);
    }
  | AddProne -> {
      let result = addCondition(character, Prone);
      withCharacter(model, result.character, result.line);
    }
  | RemoveProne -> {
      let result = removeCondition(character, Prone);
      withCharacter(model, result.character, result.line);
    }
  | AddConditionById p -> {
      let condition = conditionFromId(fieldText(p));
      let result = addCondition(character, condition);
      withCharacter(model, result.character, result.line);
    }
  | RemoveConditionById p -> {
      let condition = conditionFromId(fieldText(p));
      let result = removeCondition(character, condition);
      withCharacter(model, result.character, result.line);
    }
  | ToggleContentPack p -> {
      let packs = toggleContentPack(model.contentPacks, fieldText(p));
      withContentPacks(model, packs, "Content pack toggled");
    }
  | ResetSample -> {
      let documents = initialDocuments();
      let doc = firstDocument(documents);
      buildModel(model, documents, doc.id, doc.character, doc.turn, "Reset sample characters", "7", "6", "5", "", "", defaultSelection());
    }
}


import * from "./app/appui";

run(init(), view, update);
