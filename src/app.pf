function slotOneId() { "slot-1"; }
function slotTwoId() { "slot-2"; }
function slotThreeId() { "slot-3"; }
function slotFourId() { "slot-4"; }
function slotFiveId() { "slot-5"; }
function slotSixId() { "slot-6"; }

function scoreSlotValue(selection, slotId) {
  if slotId == slotOneId() then
    selection.scoreSlotOne
  else if slotId == slotTwoId() then
    selection.scoreSlotTwo
  else if slotId == slotThreeId() then
    selection.scoreSlotThree
  else if slotId == slotFourId() then
    selection.scoreSlotFour
  else if slotId == slotFiveId() then
    selection.scoreSlotFive
  else if slotId == slotSixId() then
    selection.scoreSlotSix
  else
    "";
}

function scoreSlotInt(selection, slotId) {
  intFromText(scoreSlotValue(selection, slotId));
}

function assignedSlotForAbility(selection, ability) {
  if ability == Strength then
    selection.standardStrength
  else if ability == Dexterity then
    selection.standardDexterity
  else if ability == Constitution then
    selection.standardConstitution
  else if ability == Intelligence then
    selection.standardIntelligence
  else if ability == Wisdom then
    selection.standardWisdom
  else
    selection.standardCharisma;
}

function setAssignedSlotForAbility(selection, ability, slotId) {
  let str = ability == Strength ? slotId : selection.standardStrength;
  let dex = ability == Dexterity ? slotId : selection.standardDexterity;
  let con = ability == Constitution ? slotId : selection.standardConstitution;
  let intv = ability == Intelligence ? slotId : selection.standardIntelligence;
  let wis = ability == Wisdom ? slotId : selection.standardWisdom;
  let cha = ability == Charisma ? slotId : selection.standardCharisma;
  makeSelection(selection, selection.activeTab, selection.builderStep, selection.equipmentCategory, selection.equipmentSearch, selection.expandedSections, selection.abilityMethod, "", str, dex, con, intv, wis, cha, selection.scoreSlotOne, selection.scoreSlotTwo, selection.scoreSlotThree, selection.scoreSlotFour, selection.scoreSlotFive, selection.scoreSlotSix, selection.backgroundBonusMode, selection.backgroundBonusPrimary, selection.backgroundBonusSecondary, selection.backgroundBonusTertiary, selection.rollMode, selection.rollSeed, selection.rollSummary);
}

function clearSlotAssignment(selection, slotId) {
  let str = selection.standardStrength == slotId ? "" : selection.standardStrength;
  let dex = selection.standardDexterity == slotId ? "" : selection.standardDexterity;
  let con = selection.standardConstitution == slotId ? "" : selection.standardConstitution;
  let intv = selection.standardIntelligence == slotId ? "" : selection.standardIntelligence;
  let wis = selection.standardWisdom == slotId ? "" : selection.standardWisdom;
  let cha = selection.standardCharisma == slotId ? "" : selection.standardCharisma;
  makeSelection(selection, selection.activeTab, selection.builderStep, selection.equipmentCategory, selection.equipmentSearch, selection.expandedSections, selection.abilityMethod, selection.standardSelectedScore, str, dex, con, intv, wis, cha, selection.scoreSlotOne, selection.scoreSlotTwo, selection.scoreSlotThree, selection.scoreSlotFour, selection.scoreSlotFive, selection.scoreSlotSix, selection.backgroundBonusMode, selection.backgroundBonusPrimary, selection.backgroundBonusSecondary, selection.backgroundBonusTertiary, selection.rollMode, selection.rollSeed, selection.rollSummary);
}

function clearAbilityAssignment(selection, ability) {
  setAssignedSlotForAbility(selection, ability, "");
}

function assignSelectedScoreSlot(selection, ability) {
  let selected = selection.standardSelectedScore;
  let currentlyAssigned = assignedSlotForAbility(selection, ability);
  if selected == "" then {
    if currentlyAssigned == "" then
      selection
    else
      clearAbilityAssignment(selection, ability);
  } else {
    let withoutSelected = clearSlotAssignment(selection, selected);
    setAssignedSlotForAbility(withoutSelected, ability, selected);
  }
}

function selectionWithScoreSlots(selection, s1, s2, s3, s4, s5, s6, summary) {
  makeSelection(selection, selection.activeTab, selection.builderStep, selection.equipmentCategory, selection.equipmentSearch, selection.expandedSections, selection.abilityMethod, "", "", "", "", "", "", "", __str__(s1), __str__(s2), __str__(s3), __str__(s4), __str__(s5), __str__(s6), selection.backgroundBonusMode, selection.backgroundBonusPrimary, selection.backgroundBonusSecondary, selection.backgroundBonusTertiary, selection.rollMode, selection.rollSeed, summary);
}

function standardArraySelection(selection) {
  selectionWithScoreSlots(selection, 15, 14, 13, 12, 10, 8, "Standard array ready");
}

function rolledScoreSelection(selection, scores, summary) {
  selectionWithScoreSlots(selection, scores.strength, scores.dexterity, scores.constitution, scores.intelligence, scores.wisdom, scores.charisma, summary);
}

function standardArrayDefaultSelection(selection) {
  makeSelection(selection, selection.activeTab, selection.builderStep, selection.equipmentCategory, selection.equipmentSearch, selection.expandedSections, selection.abilityMethod, "", slotOneId(), slotTwoId(), slotThreeId(), slotFourId(), slotFiveId(), slotSixId(), "15", "14", "13", "12", "10", "8", selection.backgroundBonusMode, selection.backgroundBonusPrimary, selection.backgroundBonusSecondary, selection.backgroundBonusTertiary, selection.rollMode, selection.rollSeed, "Standard array applied");
}

function clearStandardArraySelection(selection) {
  makeSelection(selection, selection.activeTab, selection.builderStep, selection.equipmentCategory, selection.equipmentSearch, selection.expandedSections, selection.abilityMethod, "", "", "", "", "", "", "", "", "", "", "", "", "", selection.backgroundBonusMode, selection.backgroundBonusPrimary, selection.backgroundBonusSecondary, selection.backgroundBonusTertiary, selection.rollMode, selection.rollSeed, selection.rollSummary);
}

function scoresFromAssignments(selection) {
  AbilityScores(
    strength = selection.standardStrength == "" ? 8 : scoreSlotInt(selection, selection.standardStrength),
    dexterity = selection.standardDexterity == "" ? 8 : scoreSlotInt(selection, selection.standardDexterity),
    constitution = selection.standardConstitution == "" ? 8 : scoreSlotInt(selection, selection.standardConstitution),
    intelligence = selection.standardIntelligence == "" ? 8 : scoreSlotInt(selection, selection.standardIntelligence),
    wisdom = selection.standardWisdom == "" ? 8 : scoreSlotInt(selection, selection.standardWisdom),
    charisma = selection.standardCharisma == "" ? 8 : scoreSlotInt(selection, selection.standardCharisma)
  );
}

function applyAssignmentSelection(character, selection) {
  applyScoresWithBackgroundBonuses(character, scoresFromAssignments(selection), selection);
}

function assignSelectedStandardScore(character, ability, selection) {
  let nextSelection = assignSelectedScoreSlot(selection, ability);
  applyAssignmentSelection(character, nextSelection);
}

