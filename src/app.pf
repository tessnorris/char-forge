function syncedDocuments(model, character, turn) {
  replaceDocument(model.documents, makeCharacterDocument(model.selectedId, character, turn));
}

function buildModel(model, documents, selectedId, character, turn, status, damageText, healingText, tempText, saveText, importText, selection) {
  noCmd(Model(
    catalog = model.catalog,
    contentPacks = model.contentPacks,
    documents = documents,
    selectedId = selectedId,
    character = character,
    turn = turn,
    status = status,
    damageText = damageText,
    healingText = healingText,
    tempText = tempText,
    saveText = saveText,
    importText = importText,
    selection = selection
  ));
}

function withModel(model, character, turn, status, damageText, healingText, tempText, saveText, importText, selection) {
  let documents = syncedDocuments(model, character, turn);
  buildModel(model, documents, model.selectedId, character, turn, status, damageText, healingText, tempText, saveText, importText, selection);
}

function withCharacter(model, character, status) {
  withModel(model, character, model.turn, status, model.damageText, model.healingText, model.tempText, model.saveText, model.importText, model.selection);
}

function withTurn(model, turn, status) {
  withModel(model, model.character, turn, status, model.damageText, model.healingText, model.tempText, model.saveText, model.importText, model.selection);
}

function withInputs(model, damageText, healingText, tempText, status) {
  withModel(model, model.character, model.turn, status, damageText, healingText, tempText, model.saveText, model.importText, model.selection);
}

function withSelection(model, selection, status) {
  withModel(model, model.character, model.turn, status, model.damageText, model.healingText, model.tempText, model.saveText, model.importText, selection);
}


function withSaveText(model, saveText, status) {
  withModel(model, model.character, model.turn, status, model.damageText, model.healingText, model.tempText, saveText, model.importText, model.selection);
}

function withImportText(model, importText, status) {
  withModel(model, model.character, model.turn, status, model.damageText, model.healingText, model.tempText, model.saveText, importText, model.selection);
}

function selectedDocument(model) {
  makeCharacterDocument(model.selectedId, model.character, model.turn);
}

