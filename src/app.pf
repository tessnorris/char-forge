function setSelectionStandardAssignment(selection, ability, value) {
  let str = ability == Strength ? value : selection.standardStrength;
  let dex = ability == Dexterity ? value : selection.standardDexterity;
  let con = ability == Constitution ? value : selection.standardConstitution;
  let intv = ability == Intelligence ? value : selection.standardIntelligence;
  let wis = ability == Wisdom ? value : selection.standardWisdom;
  let cha = ability == Charisma ? value : selection.standardCharisma;
  makeSelection(selection, selection.activeTab, selection.builderStep, selection.equipmentCategory, selection.equipmentSearch, selection.expandedSections, selection.abilityMethod, "", str, dex, con, intv, wis, cha, selection.backgroundBonusMode, selection.backgroundBonusPrimary, selection.backgroundBonusSecondary, selection.backgroundBonusTertiary, selection.rollMode, selection.rollSeed, selection.rollSummary);
}

function selectedStandardScoreInt(selection) {
  intFromText(selection.standardSelectedScore);
}

function assignSelectedStandardScore(character, ability, selection) {
  if selection.standardSelectedScore == "" then
    character
  else
    setScoreWithBackgroundBonuses(character, ability, selectedStandardScoreInt(selection), selection);
}

