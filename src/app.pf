  makeSelection(selection, selection.activeTab, selection.builderStep, selection.equipmentCategory, selection.equipmentSearch, selection.expandedSections, selection.abilityMethod, selection.standardSelectedScore, selection.standardStrength, selection.standardDexterity, selection.standardConstitution, selection.standardIntelligence, selection.standardWisdom, selection.standardCharisma, selection.scoreSlotOne, selection.scoreSlotTwo, selection.scoreSlotThree, selection.scoreSlotFour, selection.scoreSlotFive, selection.scoreSlotSix, selection.backgroundBonusMode, selection.backgroundBonusPrimary, selection.backgroundBonusSecondary, value, selection.rollMode, selection.rollSeed, selection.rollSummary);
