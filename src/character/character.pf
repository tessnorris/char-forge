  | AbyssalLineage -> "abyssal"
  | ChthonicLineage -> "chthonic"
  | InfernalLineage -> "infernal";
}

export function tieflingLineageFromId(id) {
  if id == "abyssal" then AbyssalLineage
  else if id == "chthonic" then ChthonicLineage
  else if id == "infernal" then InfernalLineage
  else InfernalLineage;
}

export function tieflingLineageResistance(lineage) {
  match lineage with
  | AbyssalLineage -> "Poison"
  | ChthonicLineage -> "Necrotic"
  | InfernalLineage -> "Fire";
}

export function abilitySpellcastingName(id) {
  if id == "int" then "Intelligence"
  else if id == "wis" then "Wisdom"
  else if id == "cha" then "Charisma"
  else "Intelligence";
}

export function skillFromId(id, fallback) {
  if id == "athletics" then Athletics
  else if id == "acrobatics" then Acrobatics
  else if id == "sleight-of-hand" then SleightOfHand
  else if id == "stealth" then Stealth
  else if id == "arcana" then Arcana
  else if id == "history" then History
  else if id == "investigation" then Investigation
  else if id == "nature" then Nature
  else if id == "religion" then Religion
  else if id == "animal-handling" then AnimalHandling
  else if id == "insight" then Insight
  else if id == "medicine" then Medicine
  else if id == "perception" then Perception
  else if id == "survival" then Survival
  else if id == "deception" then Deception
  else if id == "intimidation" then Intimidation
  else if id == "performance" then Performance
  else if id == "persuasion" then Persuasion
  else fallback;
}

export function skillId(skill) {
  match skill with
  | Insight -> "insight"
  | Perception -> "perception"
  | Survival -> "survival"
  | Athletics -> "athletics"
  | Acrobatics -> "acrobatics"
  | SleightOfHand -> "sleight-of-hand"
  | Stealth -> "stealth"
  | Arcana -> "arcana"
  | History -> "history"
  | Investigation -> "investigation"
  | Nature -> "nature"
  | Religion -> "religion"
  | AnimalHandling -> "animal-handling"
  | Medicine -> "medicine"
  | Deception -> "deception"
  | Intimidation -> "intimidation"
  | Performance -> "performance"
  | Persuasion -> "persuasion";
}

export function fightingStyleName(style) {
  match style with
  | NoFightingStyle -> "None"
  | ArcheryStyle -> "Archery"
  | DefenseStyle -> "Defense"
  | DuelingStyle -> "Dueling"
  | GreatWeaponFightingStyle -> "Great Weapon Fighting"
  | ProtectionStyle -> "Protection"
  | TwoWeaponFightingStyle -> "Two-Weapon Fighting";
}

export function fightingStyleId(style) {
  match style with
  | NoFightingStyle -> "none"
  | ArcheryStyle -> "archery"
  | DefenseStyle -> "defense"
  | DuelingStyle -> "dueling"
  | GreatWeaponFightingStyle -> "great-weapon"
  | ProtectionStyle -> "protection"
  | TwoWeaponFightingStyle -> "two-weapon";
}

export function fightingStyleFromId(id) {
  if id == "archery" then ArcheryStyle
  else if id == "defense" then DefenseStyle
  else if id == "dueling" then DuelingStyle
  else if id == "great-weapon" then GreatWeaponFightingStyle
  else if id == "protection" then ProtectionStyle
  else if id == "two-weapon" then TwoWeaponFightingStyle
  else NoFightingStyle;
}

export function clericOrderName(order) {
  match order with
  | NoClericOrder -> "None"
  | ProtectorOrder -> "Protector"
  | ThaumaturgeOrder -> "Thaumaturge";
}

export function clericOrderId(order) {
  match order with
  | NoClericOrder -> "none"
  | ProtectorOrder -> "protector"
  | ThaumaturgeOrder -> "thaumaturge";
}

export function clericOrderFromId(id) {
  if id == "protector" then ProtectorOrder
  else if id == "thaumaturge" then ThaumaturgeOrder
  else NoClericOrder;
}

export function druidOrderName(order) {
  match order with
  | NoDruidOrder -> "None"
  | MagicianOrder -> "Magician"
  | WardenOrder -> "Warden";
}

export function druidOrderId(order) {
  match order with
  | NoDruidOrder -> "none"
  | MagicianOrder -> "magician"
  | WardenOrder -> "warden";
}

export function druidOrderFromId(id) {
  if id == "magician" then MagicianOrder
  else if id == "warden" then WardenOrder
  else NoDruidOrder;
}

export function allSkills() {
  [Athletics, Acrobatics, SleightOfHand, Stealth, Arcana, History, Investigation, Nature, Religion, AnimalHandling, Insight, Medicine, Perception, Survival, Deception, Intimidation, Performance, Persuasion];
}

export function classSkillOptions(class) {
  match class with
  | Barbarian -> [AnimalHandling, Athletics, Intimidation, Nature, Perception, Survival]
  | Bard -> allSkills()
  | Cleric -> [History, Insight, Medicine, Persuasion, Religion]
  | Druid -> [Arcana, AnimalHandling, Insight, Medicine, Nature, Perception, Religion, Survival]
  | Fighter -> [Acrobatics, AnimalHandling, Athletics, History, Insight, Intimidation, Perception, Survival]
  | Monk -> [Acrobatics, Athletics, History, Insight, Religion, Stealth]
  | Paladin -> [Athletics, Insight, Intimidation, Medicine, Persuasion, Religion]
  | Ranger -> [AnimalHandling, Athletics, Insight, Investigation, Nature, Perception, Stealth, Survival]
  | Rogue -> [Acrobatics, Athletics, Deception, Insight, Intimidation, Investigation, Perception, Persuasion, SleightOfHand, Stealth]
  | Sorcerer -> [Arcana, Deception, Insight, Intimidation, Persuasion, Religion]
  | Warlock -> [Arcana, Deception, History, Intimidation, Investigation, Nature, Religion]
  | Wizard -> [Arcana, History, Insight, Investigation, Medicine, Religion];
}

export function classSkillChoiceCount(class) {
  match class with
  | Bard -> 3
  | Ranger -> 3
  | Rogue -> 4
  | Barbarian -> 2
  | Cleric -> 2
  | Druid -> 2
  | Fighter -> 2
  | Monk -> 2
  | Paladin -> 2
  | Sorcerer -> 2
  | Warlock -> 2
  | Wizard -> 2;
}

export function defaultClassSkills(class) {
  take(classSkillChoiceCount(class), classSkillOptions(class));
}

export function defaultFightingStyle(class) {
  if className(class) == "Fighter" then DefenseStyle else NoFightingStyle;
}

export function defaultClericOrder(class) {
  if className(class) == "Cleric" then ThaumaturgeOrder else NoClericOrder;
}

export function defaultDruidOrder(class) {
  if className(class) == "Druid" then WardenOrder else NoDruidOrder;
}

export function defaultClassOptions(class) {
  let skills = defaultClassSkills(class);
  ClassOptions(
    classSkills = skills,
    fightingStyle = defaultFightingStyle(class),
    clericOrder = defaultClericOrder(class),
    druidOrder = defaultDruidOrder(class),
    expertiseSkillOne = head(skills),
    expertiseSkillTwo = head(tail(skills))
  );
}

export function hasFightingStyleOption(class) {
  let name = className(class);
  name == "Fighter" || name == "Paladin" || name == "Ranger";
}

export function hasClericOrderOption(class) {
  className(class) == "Cleric";
}

export function hasDruidOrderOption(class) {
  className(class) == "Druid";
}

export function hasExpertiseOption(class) {
  let name = className(class);
  name == "Rogue" || name == "Bard";
}

export function classOptionsLine(class, options) {
  let skills = join([skillName(s) for s <- options.classSkills], ", ");
  let style = hasFightingStyleOption(class) ? ("; Fighting Style: " + fightingStyleName(options.fightingStyle)) : "";
  let cleric = hasClericOrderOption(class) ? ("; Divine Order: " + clericOrderName(options.clericOrder)) : "";
  let druid = hasDruidOrderOption(class) ? ("; Primal Order: " + druidOrderName(options.druidOrder)) : "";
  let expertise = hasExpertiseOption(class) ? ("; Expertise: " + skillName(options.expertiseSkillOne) + ", " + skillName(options.expertiseSkillTwo)) : "";
  "Skills: " + skills + style + cleric + druid + expertise;
}


export function defaultSpeciesOptions(species) {
  if speciesName(species) == "Dragonborn" then
    SpeciesOptions(dragonbornAncestry = RedDragonAncestry, elfLineage = NoElfLineage, elfBonusSkill = Perception, gnomeLineage = ForestGnomeLineage, goliathAncestry = CloudGiantAncestry, humanBonusSkill = Perception, humanBonusFeat = "skilled", tieflingLineage = InfernalLineage, lineageSpellcastingAbility = "cha")
  else if speciesName(species) == "Elf" then
    SpeciesOptions(dragonbornAncestry = RedDragonAncestry, elfLineage = HighElfLineage, elfBonusSkill = Perception, gnomeLineage = ForestGnomeLineage, goliathAncestry = CloudGiantAncestry, humanBonusSkill = Perception, humanBonusFeat = "skilled", tieflingLineage = InfernalLineage, lineageSpellcastingAbility = "int")
  else if speciesName(species) == "Gnome" then
    SpeciesOptions(dragonbornAncestry = RedDragonAncestry, elfLineage = NoElfLineage, elfBonusSkill = Perception, gnomeLineage = ForestGnomeLineage, goliathAncestry = CloudGiantAncestry, humanBonusSkill = Perception, humanBonusFeat = "skilled", tieflingLineage = InfernalLineage, lineageSpellcastingAbility = "int")
  else if speciesName(species) == "Goliath" then
    SpeciesOptions(dragonbornAncestry = RedDragonAncestry, elfLineage = NoElfLineage, elfBonusSkill = Perception, gnomeLineage = ForestGnomeLineage, goliathAncestry = CloudGiantAncestry, humanBonusSkill = Perception, humanBonusFeat = "skilled", tieflingLineage = InfernalLineage, lineageSpellcastingAbility = "cha")
  else if speciesName(species) == "Human" then
    SpeciesOptions(dragonbornAncestry = RedDragonAncestry, elfLineage = NoElfLineage, elfBonusSkill = Perception, gnomeLineage = ForestGnomeLineage, goliathAncestry = CloudGiantAncestry, humanBonusSkill = Perception, humanBonusFeat = "skilled", tieflingLineage = InfernalLineage, lineageSpellcastingAbility = "cha")
  else if speciesName(species) == "Tiefling" then
    SpeciesOptions(dragonbornAncestry = RedDragonAncestry, elfLineage = NoElfLineage, elfBonusSkill = Perception, gnomeLineage = ForestGnomeLineage, goliathAncestry = CloudGiantAncestry, humanBonusSkill = Perception, humanBonusFeat = "skilled", tieflingLineage = InfernalLineage, lineageSpellcastingAbility = "cha")
  else
    SpeciesOptions(dragonbornAncestry = RedDragonAncestry, elfLineage = NoElfLineage, elfBonusSkill = Perception, gnomeLineage = ForestGnomeLineage, goliathAncestry = CloudGiantAncestry, humanBonusSkill = Perception, humanBonusFeat = "skilled", tieflingLineage = InfernalLineage, lineageSpellcastingAbility = "cha");
}

export function speciesOptionsLine(species, options) {
  if speciesName(species) == "Dragonborn" then
    "Draconic Ancestry: " + dragonbornAncestryName(options.dragonbornAncestry)
  else if speciesName(species) == "Elf" then
    "Lineage: " + elfLineageName(options.elfLineage) + "; Skill: " + skillName(options.elfBonusSkill)
  else if speciesName(species) == "Gnome" then
    "Lineage: " + gnomeLineageName(options.gnomeLineage)
  else if speciesName(species) == "Goliath" then
    "Giant Ancestry: " + goliathAncestryName(options.goliathAncestry)
  else if speciesName(species) == "Human" then
    "Skill: " + skillName(options.humanBonusSkill) + "; Feat: " + options.humanBonusFeat
  else if speciesName(species) == "Tiefling" then
    "Legacy: " + tieflingLineageName(options.tieflingLineage)
  else
    "No species options";
}

export function speciesName(species) {
  match species with
  | Aasimar -> "Aasimar"
  | Dragonborn -> "Dragonborn"
  | Dwarf -> "Dwarf"
  | Elf -> "Elf"
  | Gnome -> "Gnome"
  | Goliath -> "Goliath"
  | Halfling -> "Halfling"
  | Human -> "Human"
  | Orc -> "Orc"
  | Tiefling -> "Tiefling";
}

