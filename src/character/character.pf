export type RuleBonus = { target, amount, source }
export type CharacterRules = { savingThrows, skillProficiencies, toolProficiencies, armorProficiencies, weaponProficiencies, speciesTraits, classFeatures, backgroundTraits, feats, features, bonuses }
export type DerivedStats = { proficiencyBonus, armorClass, initiativeMod, hitPointMax, passivePerception, carryingCapacity }
export type PlayStats = { currentHp, temporaryHp, hitDiceRemaining, isConscious }


export function genderName(gender) {
  match gender with
  | UnspecifiedGender -> "Any"
  | MaleGender -> "Male"
  | NonbinaryGender -> "Non-binary"
  | FemaleGender -> "Female";
}

export function genderId(gender) {
  match gender with
  | UnspecifiedGender -> "any"
  | MaleGender -> "male"
  | NonbinaryGender -> "nonbinary"
  | FemaleGender -> "female";
}

export function genderFromId(id) {
  if id == "male" then
    MaleGender
  else if id == "nonbinary" then
    NonbinaryGender
  else if id == "female" then
    FemaleGender
  else
    UnspecifiedGender;
}

export function dragonbornAncestryName(ancestry) {
  match ancestry with
  | BlackDragonAncestry -> "Black"
  | BlueDragonAncestry -> "Blue"
  | BrassDragonAncestry -> "Brass"
  | BronzeDragonAncestry -> "Bronze"
  | CopperDragonAncestry -> "Copper"
  | GoldDragonAncestry -> "Gold"
  | GreenDragonAncestry -> "Green"
  | RedDragonAncestry -> "Red"
  | SilverDragonAncestry -> "Silver"
  | WhiteDragonAncestry -> "White";
}

export function dragonbornAncestryId(ancestry) {
  match ancestry with
  | BlackDragonAncestry -> "black"
  | BlueDragonAncestry -> "blue"
  | BrassDragonAncestry -> "brass"
  | BronzeDragonAncestry -> "bronze"
  | CopperDragonAncestry -> "copper"
  | GoldDragonAncestry -> "gold"
  | GreenDragonAncestry -> "green"
  | RedDragonAncestry -> "red"
  | SilverDragonAncestry -> "silver"
  | WhiteDragonAncestry -> "white";
}

export function dragonbornAncestryFromId(id) {
  if id == "black" then BlackDragonAncestry
  else if id == "blue" then BlueDragonAncestry
  else if id == "brass" then BrassDragonAncestry
  else if id == "bronze" then BronzeDragonAncestry
  else if id == "copper" then CopperDragonAncestry
  else if id == "gold" then GoldDragonAncestry
  else if id == "green" then GreenDragonAncestry
  else if id == "red" then RedDragonAncestry
  else if id == "silver" then SilverDragonAncestry
  else if id == "white" then WhiteDragonAncestry
  else RedDragonAncestry;
}

export function dragonbornAncestryDamage(ancestry) {
  match ancestry with
  | BlackDragonAncestry -> "Acid"
  | BlueDragonAncestry -> "Lightning"
  | BrassDragonAncestry -> "Fire"
  | BronzeDragonAncestry -> "Lightning"
  | CopperDragonAncestry -> "Acid"
  | GoldDragonAncestry -> "Fire"
  | GreenDragonAncestry -> "Poison"
  | RedDragonAncestry -> "Fire"
  | SilverDragonAncestry -> "Cold"
  | WhiteDragonAncestry -> "Cold";
}


export function elfLineageName(lineage) {
  match lineage with
  | NoElfLineage -> "None"
  | DrowLineage -> "Drow"
  | HighElfLineage -> "High Elf"
  | WoodElfLineage -> "Wood Elf";
}

export function elfLineageId(lineage) {
  match lineage with
  | NoElfLineage -> "none"
  | DrowLineage -> "drow"
  | HighElfLineage -> "high"
  | WoodElfLineage -> "wood";
}

export function elfLineageFromId(id) {
  if id == "drow" then
    DrowLineage
  else if id == "high" then
    HighElfLineage
  else if id == "wood" then
    WoodElfLineage
  else
    NoElfLineage;
}

