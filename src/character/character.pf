  | Monk -> "Monk"
  | Paladin -> "Paladin"
  | Ranger -> "Ranger"
  | Rogue -> "Rogue"
  | Sorcerer -> "Sorcerer"
  | Warlock -> "Warlock"
  | Wizard -> "Wizard";
}

