export function armorName(armor) {
  match armor with
  | NoArmor -> "No armor"
  | PaddedArmor -> "Padded armor"
  | LeatherArmor -> "Leather armor"
  | StuddedLeatherArmor -> "Studded leather armor"
  | ChainShirt -> "Chain shirt"
  | ScaleMail -> "Scale mail"
  | ChainMail -> "Chain mail";
}

export function toolName(tool) {
  match tool with
  | ThievesTools -> "Thieves' tools"
  | HerbalismKit -> "Herbalism kit"
  | DisguiseKit -> "Disguise kit"
  | PlayingCards -> "Playing cards";
}

export function gearName(gear) {
  match gear with
  | ExplorerPack -> "Explorer's pack"
  | ScholarPack -> "Scholar's pack"
  | HolySymbol -> "Holy symbol"
  | Spellbook -> "Spellbook"
  | Rope -> "Rope"
  | Torch -> "Torch";
}

export function equipmentNames(loadout) {
  let weaponNames = [ weaponName(w) for w <- loadout.weapons ];
  let armorNames = [ armorName(a) for a <- loadout.armor ];
  let toolNames = [ toolName(t) for t <- loadout.tools ];
  let gearNames = [ gearName(g) for g <- loadout.gear ];
  let shieldNames = loadout.hasShield ? ["Shield"] : [];
  weaponNames + armorNames + toolNames + gearNames + shieldNames;
}

export function weaponAbility(weapon) {
  match weapon with
  | Dagger -> Dexterity
  | Shortsword -> Dexterity
  | Shortbow -> Dexterity
  | Longbow -> Dexterity
  | Club -> Strength
  | Quarterstaff -> Strength
  | Longsword -> Strength;
}

export function weaponDamage(weapon) {
  match weapon with
  | Club -> "1d4"
  | Dagger -> "1d4"
  | Quarterstaff -> "1d6"
  | Shortsword -> "1d6"
  | Longsword -> "1d8"
  | Shortbow -> "1d6"
  | Longbow -> "1d8";
}

export function armorBaseAc(armor) {
  match armor with
  | NoArmor -> 10
  | PaddedArmor -> 11
  | LeatherArmor -> 11
  | StuddedLeatherArmor -> 12
  | ChainShirt -> 13
  | ScaleMail -> 14
  | ChainMail -> 16;
}

export function armorDexLimit(armor) {
  match armor with
  | NoArmor -> 99
  | PaddedArmor -> 99
  | LeatherArmor -> 99
  | StuddedLeatherArmor -> 99
  | ChainShirt -> 2
  | ScaleMail -> 2
  | ChainMail -> 0;
}

export function minInt(a, b) {
  a < b ? a : b;
}

export function hitDie(class) {
  match class with
  | Barbarian -> 12
  | Bard -> 8
  | Cleric -> 8
  | Druid -> 8
  | Fighter -> 10
  | Monk -> 8
  | Paladin -> 10
  | Ranger -> 10
  | Rogue -> 8
  | Sorcerer -> 6
  | Warlock -> 8
  | Wizard -> 6;
}

export function proficiencyBonusForLevel(level) {
  2 + ((level - 1) / 4);
}

export function hasArmor(armor, armors) {
  length(filter(fn item => item == armor, armors)) > 0;
}


export function abilityBonusTarget(ability) {
  match ability with
  | Strength -> StrengthBonus
  | Dexterity -> DexterityBonus
  | Constitution -> ConstitutionBonus
  | Intelligence -> IntelligenceBonus
  | Wisdom -> WisdomBonus
  | Charisma -> CharismaBonus;
}

export function skillBonusTarget(skill) {
  match skill with
  | Athletics -> AthleticsBonus
  | Acrobatics -> AcrobaticsBonus
  | SleightOfHand -> SleightOfHandBonus
  | Stealth -> StealthBonus
  | Arcana -> ArcanaBonus
  | History -> HistoryBonus
  | Investigation -> InvestigationBonus
  | Nature -> NatureBonus
  | Religion -> ReligionBonus
  | AnimalHandling -> AnimalHandlingBonus
  | Insight -> InsightBonus
  | Medicine -> MedicineBonus
  | Perception -> PerceptionBonus
  | Survival -> SurvivalBonus
  | Deception -> DeceptionBonus
  | Intimidation -> IntimidationBonus
  | Performance -> PerformanceBonus
  | Persuasion -> PersuasionBonus;
}

export function bonusTargetName(target) {
  match target with
  | ArmorClassBonus -> "Armor Class"
  | InitiativeBonus -> "Initiative"
  | PassivePerceptionBonus -> "Passive Perception"
  | CarryingCapacityBonus -> "Carrying Capacity"
  | StrengthBonus -> "Strength"
  | DexterityBonus -> "Dexterity"
  | ConstitutionBonus -> "Constitution"
  | IntelligenceBonus -> "Intelligence"
  | WisdomBonus -> "Wisdom"
  | CharismaBonus -> "Charisma"
  | AthleticsBonus -> "Athletics"
  | AcrobaticsBonus -> "Acrobatics"
  | SleightOfHandBonus -> "Sleight of Hand"
  | StealthBonus -> "Stealth"
  | ArcanaBonus -> "Arcana"
  | HistoryBonus -> "History"
  | InvestigationBonus -> "Investigation"
  | NatureBonus -> "Nature"
  | ReligionBonus -> "Religion"
  | AnimalHandlingBonus -> "Animal Handling"
  | InsightBonus -> "Insight"
  | MedicineBonus -> "Medicine"
  | PerceptionBonus -> "Perception"
  | SurvivalBonus -> "Survival"
  | DeceptionBonus -> "Deception"
  | IntimidationBonus -> "Intimidation"
  | PerformanceBonus -> "Performance"
  | PersuasionBonus -> "Persuasion";
}

export function bonusesForTarget(rules, target) {
  filter(fn b => b.target == target, rules.bonuses);
}

export function sumBonusList(bonuses) {
  reduce(fn acc, b => acc + b.amount, 0, bonuses);
}

export function ruleBonus(rules, target) {
  sumBonusList(bonusesForTarget(rules, target));
}

export function abilityRuleBonus(rules, ability) {
  ruleBonus(rules, abilityBonusTarget(ability));
}

export function skillRuleBonus(rules, skill) {
  ruleBonus(rules, skillBonusTarget(skill));
}

export function equippedArmor(character) {
  let build = character.build;
  let armors = build.loadout.armor;
  if hasArmor(ChainMail, armors) then
    ChainMail
  else if hasArmor(ScaleMail, armors) then
    ScaleMail
  else if hasArmor(ChainShirt, armors) then
    ChainShirt
  else if hasArmor(StuddedLeatherArmor, armors) then
    StuddedLeatherArmor
  else if hasArmor(LeatherArmor, armors) then
    LeatherArmor
  else if hasArmor(PaddedArmor, armors) then
    PaddedArmor
  else
    NoArmor;
}

export function armorClass(character, rules) {
  let build = character.build;
  let armor = equippedArmor(character);
  let dex = abilityMod(getScore(build.scores, Dexterity) + abilityRuleBonus(rules, Dexterity));
  let dexPart = minInt(dex, armorDexLimit(armor));
  let shieldPart = build.loadout.hasShield ? 2 : 0;
  armorBaseAc(armor) + dexPart + shieldPart + ruleBonus(rules, ArmorClassBonus);
}

export function initiativeMod(character, rules) {
  let build = character.build;
  abilityMod(getScore(build.scores, Dexterity) + abilityRuleBonus(rules, Dexterity)) + ruleBonus(rules, InitiativeBonus);
}

export function hitPointMax(character) {
  let build = character.build;
  let con = abilityMod(getScore(build.scores, Constitution));
  hitDie(build.class) + con + ((build.level - 1) * ((hitDie(build.class) / 2) + 1 + con));
}

export function carryingCapacity(character, rules) {
  let build = character.build;
  (getScore(build.scores, Strength) + abilityRuleBonus(rules, Strength)) * 15 + ruleBonus(rules, CarryingCapacityBonus);
}

export function hasSkill(skill, skills) {
  length(filter(fn s => s == skill, skills)) > 0;
}

export function skillAbility(skill) {
  match skill with
  | Athletics -> Strength
  | Acrobatics -> Dexterity
  | SleightOfHand -> Dexterity
  | Stealth -> Dexterity
  | Arcana -> Intelligence
  | History -> Intelligence
  | Investigation -> Intelligence
  | Nature -> Intelligence
  | Religion -> Intelligence
  | AnimalHandling -> Wisdom
  | Insight -> Wisdom
  | Medicine -> Wisdom
  | Perception -> Wisdom
  | Survival -> Wisdom
  | Deception -> Charisma
  | Intimidation -> Charisma
  | Performance -> Charisma
  | Persuasion -> Charisma;
}

export function skillBonus(character, rules, skill) {
  let build = character.build;
  let ability = skillAbility(skill);
  let abilityScore = getScore(build.scores, ability) + abilityRuleBonus(rules, ability);
  let base = abilityMod(abilityScore);
  let prof = hasSkill(skill, rules.skillProficiencies) ? proficiencyBonusForLevel(build.level) : 0;
  base + prof + skillRuleBonus(rules, skill);
}

export function passivePerception(character, rules) {
  10 + skillBonus(character, rules, Perception) + ruleBonus(rules, PassivePerceptionBonus);
}


export function hasWeapon(weapon, weapons) {
  length(filter(fn w => w == weapon, weapons)) > 0;
}

export function weaponAttackBonus(character, rules, weapon) {
  let build = character.build;
  let ability = weaponAbility(weapon);
  let prof = hasWeapon(weapon, rules.weaponProficiencies) ? proficiencyBonusForLevel(build.level) : 0;
  abilityMod(getScore(build.scores, ability) + abilityRuleBonus(rules, ability)) + prof;
}

export function weaponDamageBonus(character, weapon) {
  let build = character.build;
  let ability = weaponAbility(weapon);
  abilityMod(getScore(build.scores, ability));
}

export function weaponLine(character, rules, weapon) {
  let name = weaponName(weapon);
  let damage = weaponDamage(weapon);
  let attack = weaponAttackBonus(character, rules, weapon);
  let damageBonus = weaponDamageBonus(character, weapon);
  let attackText = formatMod(attack);
  let damageText = formatMod(damageBonus);
  $"{name}: attack {attackText}, damage {damage}{damageText}";
}

export function derive(character, rules) {
  DerivedStats(
    proficiencyBonus = proficiencyBonusForLevel(character.build.level),
    armorClass = armorClass(character, rules),
    initiativeMod = initiativeMod(character, rules),
    hitPointMax = hitPointMax(character),
    passivePerception = passivePerception(character, rules),
    carryingCapacity = carryingCapacity(character, rules)
  );
}

export function summaryLine(character) {
  let build = character.build;
  let name = build.identity.name;
  let level = build.level;
  let speciesText = speciesName(build.species);
  let classText = className(build.class);
  let backgroundText = backgroundName(build.background);
  let money = formatCurrency(build.copper);
  $"{name}: level {level} {speciesText} {classText}, {backgroundText}, {money}";
}

export function hasCondition(condition, conditions) {
  length(filter(fn c => c == condition, conditions)) > 0;
}

export function isConscious(character) {
  character.state.currentHp > 0 && !hasCondition(Unconscious, character.state.conditions);
}

export function maxInt(a, b) {
  a > b ? a : b;
}

export function hitDiceRemaining(character) {
  maxInt(0, character.build.level - character.state.hitDiceSpent);
}

export function playStats(character) {
  PlayStats(
    currentHp = character.state.currentHp,
    temporaryHp = character.state.temporaryHp,
    hitDiceRemaining = hitDiceRemaining(character),
    isConscious = isConscious(character)
  );
}

export function sampleCharacterBuild() {
  CharacterBuild(
    identity = Identity(name = "Tessa", playerName = "Player", gender = FemaleGender),
    species = Elf,
    speciesOptions = defaultSpeciesOptions(Elf),
    class = Rogue,
    classOptions = defaultClassOptions(Rogue),
    background = Criminal,
    level = 3,
    scores = AbilityScores(
      strength = 10,
      dexterity = 16,
      constitution = 14,
      intelligence = 13,
      wisdom = 12,
      charisma = 8
    ),
    loadout = EquipmentLoadout(
      weapons = [Shortsword, Dagger],
      armor = [LeatherArmor],
      tools = [ThievesTools],
      gear = [ExplorerPack],
      hasShield = false
    ),
    copper = 1234
  );
}

export function sampleCharacterState() {
  CharacterState(
    currentHp = 18,
    temporaryHp = 0,
    hitDiceSpent = 1,
    conditions = [],
    notes = ""
  );
}

export function sampleCharacter() {
  Character(
    build = sampleCharacterBuild(),
    state = sampleCharacterState()
  );
}

// Computed projection for UI/persistence boundaries.
// This is deliberately not stored. Recompute it from CharacterBuild + CharacterState.
export type SkillBonusView = { skill, name, bonus }
export type RuleBonusView = { target, targetName, amount, source, line }
export type WeaponView = { weapon, name, attackBonus, damageDie, damageBonus, line }
export type CharacterView = {
  name,
  playerName,
  gender,
  level,
  speciesName,
  className,
  backgroundName,
  currencyText,
  proficiencyBonus,
  armorClass,
  initiativeMod,
  hitPointMax,
  currentHp,
  temporaryHp,
  hitDiceRemaining,
  isConscious,
  passivePerception,
  carryingCapacity,
  savingThrows,
  backgroundSkills,
  backgroundTools,
  skillBonuses,
  equippedArmor,
  equipment,
  weapons,
  traits,
  feats,
  bonuses,
  notes
}

export function skillBonusView(character, rules, skill) {
  SkillBonusView(
    skill = skill,
    name = skillName(skill),
    bonus = skillBonus(character, rules, skill)
  );
}

export function allSkillBonuses(character, rules) {
  [
    skillBonusView(character, rules, Athletics),
    skillBonusView(character, rules, Acrobatics),
    skillBonusView(character, rules, SleightOfHand),
    skillBonusView(character, rules, Stealth),
    skillBonusView(character, rules, Arcana),
    skillBonusView(character, rules, History),
    skillBonusView(character, rules, Investigation),
    skillBonusView(character, rules, Nature),
    skillBonusView(character, rules, Religion),
    skillBonusView(character, rules, AnimalHandling),
    skillBonusView(character, rules, Insight),
    skillBonusView(character, rules, Medicine),
    skillBonusView(character, rules, Perception),
    skillBonusView(character, rules, Survival),
    skillBonusView(character, rules, Deception),
    skillBonusView(character, rules, Intimidation),
    skillBonusView(character, rules, Performance),
    skillBonusView(character, rules, Persuasion)
  ];
}

export function weaponView(character, rules, weapon) {
  WeaponView(
    weapon = weapon,
    name = weaponName(weapon),
    attackBonus = weaponAttackBonus(character, rules, weapon),
    damageDie = weaponDamage(weapon),
    damageBonus = weaponDamageBonus(character, weapon),
    line = weaponLine(character, rules, weapon)
  );
}

export function equippedWeaponViews(character, rules) {
  [ weaponView(character, rules, w) for w <- character.build.loadout.weapons ];
}


export function ruleBonusView(bonus) {
  let targetName = bonusTargetName(bonus.target);
  let amountText = formatMod(bonus.amount);
  let source = bonus.source;
  RuleBonusView(
    target = bonus.target,
    targetName = targetName,
    amount = bonus.amount,
    source = source,
    line = $"{targetName} {amountText} from {source}"
  );
}

export function ruleBonusViews(rules) {
  [ ruleBonusView(b) for b <- rules.bonuses ];
}


export function projectedTraitViews(character, rules) {
  let build = character.build;
  speciesTraitViews(speciesName(build.species), rules.speciesTraits) + classTraitViews(className(build.class), rules.classFeatures) + backgroundTraitViews(backgroundName(build.background), rules.backgroundTraits) + featTraitViews(rules.feats);
}

export function projectedFeatViews(rules) {
  featViews(rules.feats);
}

export function projectCharacterWithRules(character, rules) {
  let build = character.build;
  let state = character.state;
  let derived = derive(character, rules);
  let play = playStats(character);
  let armor = equippedArmor(character);
  CharacterView(
    name = build.identity.name,
    playerName = build.identity.playerName,
    gender = build.identity.gender,
    level = build.level,
    speciesName = speciesName(build.species),
    className = className(build.class),
    backgroundName = backgroundName(build.background),
    currencyText = formatCurrency(build.copper),
    proficiencyBonus = derived.proficiencyBonus,
    armorClass = derived.armorClass,
    initiativeMod = derived.initiativeMod,
    hitPointMax = derived.hitPointMax,
    currentHp = play.currentHp,
    temporaryHp = play.temporaryHp,
    hitDiceRemaining = play.hitDiceRemaining,
    isConscious = play.isConscious,
    passivePerception = derived.passivePerception,
    carryingCapacity = derived.carryingCapacity,
    savingThrows = [ abilityShort(a) for a <- rules.savingThrows ],
    backgroundSkills = [ skillName(s) for s <- rules.skillProficiencies ],
    backgroundTools = [ toolName(t) for t <- rules.toolProficiencies ],
    skillBonuses = allSkillBonuses(character, rules),
    equippedArmor = armorName(armor),
    equipment = equipmentNames(build.loadout),
    weapons = equippedWeaponViews(character, rules),
    traits = projectedTraitViews(character, rules),
    feats = projectedFeatViews(rules),
    bonuses = ruleBonusViews(rules),
    notes = state.notes
  );
}
