// Character Forge domain: Pfun-native character model
//
// This intentionally does not mirror the TypeScript shape. It models the
// game concepts with closed choices and pure derivations first.

import * from "./abilities";
import * from "../engine/currency";
import * from "./traits";
import * from "./feats";

