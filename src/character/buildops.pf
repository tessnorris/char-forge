// Character Forge pure build/edit operations
//
// These functions change the durable character choices. They do not touch
// session/play state, and they do not store derived values. After using one of
// these helpers, callers should recompute rules/projections from the new build.

import * from "./abilities";
import * from "./character";

export function withBuild(character, build) {
  Character(
    build = build,
    state = character.state
  );
}

export function replaceBuild(character, identity, species, speciesOptions, class, classOptions, background, level, scores, loadout, copper) {
  withBuild(
    character,
    CharacterBuild(
      identity = identity,
      species = species,
      speciesOptions = speciesOptions,
      class = class,
      classOptions = classOptions,
      background = background,
      level = level,
      scores = scores,
      loadout = loadout,
      copper = copper
    )
  );
}

export function setName(character, name) {
  let build = character.build;
  let identity = Identity(
    name = name,
    playerName = build.identity.playerName,
    gender = build.identity.gender
  );
  replaceBuild(character, identity, build.species, build.speciesOptions, build.class, build.classOptions, build.background, build.level, build.scores, build.loadout, build.copper);
}

export function setPlayerName(character, playerName) {
  let build = character.build;
  let identity = Identity(
    name = build.identity.name,
    playerName = playerName,
    gender = build.identity.gender
  );
  replaceBuild(character, identity, build.species, build.speciesOptions, build.class, build.classOptions, build.background, build.level, build.scores, build.loadout, build.copper);
}


export function setGender(character, gender) {
  let build = character.build;
  let identity = Identity(
    name = build.identity.name,
    playerName = build.identity.playerName,
    gender = gender
  );
  replaceBuild(character, identity, build.species, build.speciesOptions, build.class, build.classOptions, build.background, build.level, build.scores, build.loadout, build.copper);
}

export function setSpecies(character, species) {
  let build = character.build;
  replaceBuild(character, build.identity, species, defaultSpeciesOptions(species), build.class, build.classOptions, build.background, build.level, build.scores, build.loadout, build.copper);
}

export function withSpeciesOptions(character, options) {
  let build = character.build;
  replaceBuild(character, build.identity, build.species, options, build.class, build.classOptions, build.background, build.level, build.scores, build.loadout, build.copper);
}

export function setDragonbornAncestry(character, ancestry) {
  let o = character.build.speciesOptions;
  withSpeciesOptions(character, SpeciesOptions(dragonbornAncestry = ancestry, elfLineage = o.elfLineage, elfBonusSkill = o.elfBonusSkill, gnomeLineage = o.gnomeLineage, goliathAncestry = o.goliathAncestry, humanBonusSkill = o.humanBonusSkill, humanBonusFeat = o.humanBonusFeat, tieflingLineage = o.tieflingLineage, lineageSpellcastingAbility = o.lineageSpellcastingAbility));
}

