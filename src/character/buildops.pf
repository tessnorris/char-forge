export function setClass(character, class) {
  let build = character.build;
  replaceBuild(character, build.identity, build.species, build.speciesOptions, class, defaultClassOptions(class), build.background, build.level, build.scores, build.loadout, build.copper);
}

export function withClassOptions(character, options) {
  let build = character.build;
  replaceBuild(character, build.identity, build.species, build.speciesOptions, build.class, options, build.background, build.level, build.scores, build.loadout, build.copper);
}

export function hasSelectedClassSkill(skill, skills) {
  length(filter(fn s => s == skill, skills)) > 0;
}

export function removeClassSkill(skill, skills) {
  filter(fn s => s != skill, skills);
}

export function classOptionsWithSkills(options, skills) {
  ClassOptions(classSkills = skills, fightingStyle = options.fightingStyle, clericOrder = options.clericOrder, druidOrder = options.druidOrder, expertiseSkillOne = options.expertiseSkillOne, expertiseSkillTwo = options.expertiseSkillTwo);
}

export function toggleClassSkill(character, skill) {
  let build = character.build;
  let options = build.classOptions;
  let selected = options.classSkills;
  if hasSelectedClassSkill(skill, selected) then
    withClassOptions(character, classOptionsWithSkills(options, removeClassSkill(skill, selected)))
  else if length(selected) < classSkillChoiceCount(build.class) then
    withClassOptions(character, classOptionsWithSkills(options, selected + [skill]))
  else
    character;
}

export function setFightingStyle(character, style) {
  let o = character.build.classOptions;
  withClassOptions(character, ClassOptions(classSkills = o.classSkills, fightingStyle = style, clericOrder = o.clericOrder, druidOrder = o.druidOrder, expertiseSkillOne = o.expertiseSkillOne, expertiseSkillTwo = o.expertiseSkillTwo));
}

