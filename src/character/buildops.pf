  let o = character.build.classOptions;
  withClassOptions(character, ClassOptions(classSkills = o.classSkills, fightingStyle = o.fightingStyle, clericOrder = order, druidOrder = o.druidOrder, expertiseSkillOne = o.expertiseSkillOne, expertiseSkillTwo = o.expertiseSkillTwo));
}

export function setDruidOrder(character, order) {
  let o = character.build.classOptions;
  withClassOptions(character, ClassOptions(classSkills = o.classSkills, fightingStyle = o.fightingStyle, clericOrder = o.clericOrder, druidOrder = order, expertiseSkillOne = o.expertiseSkillOne, expertiseSkillTwo = o.expertiseSkillTwo));
}

export function setExpertiseSkillOne(character, skill) {
  let o = character.build.classOptions;
  withClassOptions(character, ClassOptions(classSkills = o.classSkills, fightingStyle = o.fightingStyle, clericOrder = o.clericOrder, druidOrder = o.druidOrder, expertiseSkillOne = skill, expertiseSkillTwo = o.expertiseSkillTwo));
}

export function setExpertiseSkillTwo(character, skill) {
  let o = character.build.classOptions;
  withClassOptions(character, ClassOptions(classSkills = o.classSkills, fightingStyle = o.fightingStyle, clericOrder = o.clericOrder, druidOrder = o.druidOrder, expertiseSkillOne = o.expertiseSkillOne, expertiseSkillTwo = skill));
}

export function setBackground(character, background) {
  let build = character.build;
  replaceBuild(character, build.identity, build.species, build.speciesOptions, build.class, build.classOptions, background, build.level, build.scores, build.loadout, build.copper);
}

export function setLevel(character, level) {
  let build = character.build;
  let cleanLevel = clampLevel(level);
  replaceBuild(character, build.identity, build.species, build.speciesOptions, build.class, build.classOptions, build.background, cleanLevel, build.scores, build.loadout, build.copper);
}

export function clampLevel(level) {
  if level < 1 then
    1
  else if level > 20 then
    20
  else
    level;
}

export function setAbilityScore(character, ability, score) {
  let build = character.build;
  let scores = setScore(build.scores, ability, score);
  replaceBuild(character, build.identity, build.species, build.speciesOptions, build.class, build.classOptions, build.background, build.level, scores, build.loadout, build.copper);
}

export function setCopper(character, copper) {
  let build = character.build;
  let cleanCopper = copper < 0 ? 0 : copper;
  replaceBuild(character, build.identity, build.species, build.speciesOptions, build.class, build.classOptions, build.background, build.level, build.scores, build.loadout, cleanCopper);
}

export function setLoadout(character, loadout) {
  let build = character.build;
  replaceBuild(character, build.identity, build.species, build.speciesOptions, build.class, build.classOptions, build.background, build.level, build.scores, loadout, build.copper);
}

export function equipWeapon(character, weapon) {
  let build = character.build;
  let loadout = build.loadout;
  let weapons = hasWeaponInList(weapon, loadout.weapons) ? loadout.weapons : loadout.weapons + [weapon];
  setLoadout(
    character,
    EquipmentLoadout(
      weapons = weapons,
      armor = loadout.armor,
      tools = loadout.tools,
      gear = loadout.gear,
      hasShield = loadout.hasShield
    )
  );
}

export function unequipWeapon(character, weapon) {
  let build = character.build;
  let loadout = build.loadout;
  setLoadout(
    character,
    EquipmentLoadout(
      weapons = filter(fn w => w != weapon, loadout.weapons),
      armor = loadout.armor,
      tools = loadout.tools,
      gear = loadout.gear,
      hasShield = loadout.hasShield
    )
  );
}

export function equipArmor(character, armor) {
  let build = character.build;
  let loadout = build.loadout;
  setLoadout(
    character,
    EquipmentLoadout(
      weapons = loadout.weapons,
      armor = [armor],
      tools = loadout.tools,
      gear = loadout.gear,
      hasShield = loadout.hasShield
    )
  );
}

export function clearArmor(character) {
  let build = character.build;
  let loadout = build.loadout;
  setLoadout(
    character,
    EquipmentLoadout(
      weapons = loadout.weapons,
      armor = [],
      tools = loadout.tools,
      gear = loadout.gear,
      hasShield = loadout.hasShield
    )
  );
}

export function setShield(character, hasShield) {
  let build = character.build;
  let loadout = build.loadout;
  setLoadout(
    character,
    EquipmentLoadout(
      weapons = loadout.weapons,
      armor = loadout.armor,
      tools = loadout.tools,
      gear = loadout.gear,
      hasShield = hasShield
    )
  );
}

export function addTool(character, tool) {
  let build = character.build;
  let loadout = build.loadout;
  let tools = hasTool(tool, loadout.tools) ? loadout.tools : loadout.tools + [tool];
  setLoadout(
    character,
    EquipmentLoadout(
      weapons = loadout.weapons,
      armor = loadout.armor,
      tools = tools,
      gear = loadout.gear,
      hasShield = loadout.hasShield
    )
  );
}

export function removeTool(character, tool) {
  let build = character.build;
  let loadout = build.loadout;
  setLoadout(
    character,
    EquipmentLoadout(
      weapons = loadout.weapons,
      armor = loadout.armor,
      tools = filter(fn t => t != tool, loadout.tools),
      gear = loadout.gear,
      hasShield = loadout.hasShield
    )
  );
}

export function addGear(character, gear) {
  let build = character.build;
  let loadout = build.loadout;
  let gearList = hasGear(gear, loadout.gear) ? loadout.gear : loadout.gear + [gear];
  setLoadout(
    character,
    EquipmentLoadout(
      weapons = loadout.weapons,
      armor = loadout.armor,
      tools = loadout.tools,
      gear = gearList,
      hasShield = loadout.hasShield
    )
  );
}

export function removeGear(character, gear) {
  let build = character.build;
  let loadout = build.loadout;
  setLoadout(
    character,
    EquipmentLoadout(
      weapons = loadout.weapons,
      armor = loadout.armor,
      tools = loadout.tools,
      gear = filter(fn g => g != gear, loadout.gear),
      hasShield = loadout.hasShield
    )
  );
}

export function hasWeaponInList(weapon, weapons) {
  length(filter(fn w => w == weapon, weapons)) > 0;
}

export function hasTool(tool, tools) {
  length(filter(fn t => t == tool, tools)) > 0;
}

export function hasGear(gear, gearList) {
  length(filter(fn g => g == gear, gearList)) > 0;
}
